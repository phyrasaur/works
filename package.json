{
  "name": "works",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "check": "astro check",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "generate:resume-pdf": "node scripts/generate-resume-pdf.mjs",
    "astro": "astro",
    "generate-types": "wrangler types",
    "format:check": "prettier --check .",
    "env:check": "bash scripts/check-environment.sh",
    "env:check:network": "bash scripts/check-environment.sh --network",
    "env:check:deploy": "bash scripts/check-environment.sh --network --deploy",
    "browser:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test --headed --workers=1",
    "test:e2e:report": "playwright show-report",
    "debug:site": "playwright test --trace on",
    "verify": "pnpm run env:check && pnpm run format:check && pnpm run check && pnpm run build",
    "verify:full": "pnpm run verify && pnpm run test:e2e"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.1",
    "astro": "^6.4.2",
    "wrangler": "^4.97.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@types/node": "^22.19.19",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "vite": "^7"
  }
}
