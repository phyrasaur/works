---
import Banner from "@/components/banner.astro";
import Title from "@/components/title.astro";
import Showcase from "@/components/showcase.astro";
import About from "@/components/about.astro";
import Head from "@/components/head.astro";
---

<html lang="en">
  <head>
    <Head />
    <title>Firas Razak ⸱ Product Design & Management</title>
  </head>
  <body>
    <Banner />
    <main>
      <Title />
      <Showcase />
      <About />
    </main>
  </body>
</html>
<style is:global>
  :root {
    --px: 3rem;
    --py: 2rem;
    --dvh: 100dvh;
    --lvh: 100lvh;
    --vh: 100vh;
  }
  @media screen and (min-width: 48rem) {
    :root {
      --px: 6rem;
      --py: 4rem;
    }
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family:
      var(--font-pp-neue-montreal),
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
    background-color: black;
    color: #ffffffbf;
    line-height: 1;
    font-size: 0.875rem;
    margin: 0;
  }
  button {
    background-color: transparent;
    border: none;
    border-radius: 0;
    font-size: inherit;
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6,
  p {
    margin: 0;
  }
  ul {
    padding: 0;
  }
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  a {
    color: inherit;
    text-decoration: none;
    &:visited {
      color: inherit;
    }
  }
  button:hover {
    cursor: pointer;
  }
  .contents {
    display: contents;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border-width: 0;
  }
</style>
