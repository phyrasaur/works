---
import Footer from "@/components/article/footer.astro";
import Header from "@/components/article/header.astro";
import Hero from "@/components/article/hero.astro";
import Section from "@/components/article/section.astro";
import Shell from "@/components/article/shell.astro";
import BackgroundMeta from "@/components/article/background-meta.astro";
import InsightList from "@/components/article/insight-list.astro";
import LightboxImage from "@/components/article/lightbox-image.astro";
import MediaFigure from "@/components/article/media-figure.astro";
import NumberedList from "@/components/article/numbered-list.astro";
import { donaid } from "@/data/donaid";
import {
  getNextShowcase,
  getPreviousShowcase,
  getShowcase,
} from "@/data/showcase";

const currentShowcase = getShowcase("donaid");
const nextShowcase = getNextShowcase("donaid");
const previousShowcase = getPreviousShowcase("donaid");
---

<Shell title="DonAid - Firas Razak">
  <Header
    runningTitle="Firas Razak"
    runningSubtitle={currentShowcase.item.title}
  />

  <Hero showcase={currentShowcase}>
    <Fragment slot="summary">
      <p>
        <strong>Public trust in charitable giving</strong> is often shaken by concerns
        over fraud, misuse of funds, and opaque money handling. These issues can turn
        an act of goodwill into a leap of faith for donors. Donations are untraceable.
      </p>
    </Fragment>
  </Hero>

  <Section
    id="background-title"
    title="Background"
    class="article-section--background"
    alignStart
  >
    <BackgroundMeta meta={donaid.backgroundMeta}>
      3 development attempts had failed, and other prospective agencies were
      unresponsive. Without a clear specification, previous teams were forced to
      guess, often mistaking the donation tracking system for a standard
      donation platform. The issue was in comprehension, not engineering.
    </BackgroundMeta>
  </Section>

  <Section id="problems-title" title="Problems">
    <NumberedList items={donaid.problems} />
  </Section>

  <Section
    id="workshop-title"
    title="Product workshop"
    dense
    titleOffset
    alignStart
  >
    <p class="article__section-copy">
      To start, I ran daily sessions with the founder until we reached enough
      shared understanding of the product. I then simplified the original
      material into a 7-page product brief to be sent to development agencies
      for quotation. After the rewrite,
      <strong>agency response rate increased from 10% to 80%.</strong>
    </p>
    <div class="article__media-grid article__media-grid--workshop">
      {donaid.workshopFigures.map((figure) => <MediaFigure figure={figure} />)}
    </div>
  </Section>

  <Section
    id="feasibility-title"
    title="Feasibility study"
    dense
    titleOffset
    alignStart
  >
    <p class="article__section-copy">
      I surveyed banking and messaging integrations to map what could be
      automated, what needed vendor buy-in, and what required a manual fallback.
      Where banks moved too slow, I proposed processing the banking side
      manually as an interim workaround.
    </p>
    <div class="article__media-grid article__media-grid--two-column">
      {
        donaid.feasibilityFigures.map((figure) => (
          <MediaFigure figure={figure} />
        ))
      }
    </div>
  </Section>

  <Section id="process-title" title="Work scoping" dense titleOffset alignStart>
    <p class="article__section-copy">
      I split the brief into Demo, MVP, and Feature Complete phases. I also
      shifted the founder's mindset to agile workflow.
    </p>
    <div class="article__media-grid article__media-grid--two-column">
      {donaid.processFigures.map((figure) => <MediaFigure figure={figure} />)}
    </div>
  </Section>

  <Section
    id="interface-title"
    title="Interface design"
    class="article-section--interface-design"
  >
    <p class="article__section-copy article__section-copy--start">
      Design was not in the agency's scope. I stepped in and delivered
      interfaces and flow diagrams in sync with dev milestones.
    </p>
    <MediaFigure
      figure={donaid.interfaceFigure}
      titleSuffix=":"
      class="media-card--interface"
    />
  </Section>

  <Section
    id="checkins-title"
    title="Engineering check-ins"
    titleOffset
    alignStart
  >
    <p class="article__section-copy">
      I ran weekly check-ins, taking progress reports from the dev team while
      handing over design for the next task. I bridged the founder and dev
      across system design, business logic, architecture, and acceptance
      criteria.
    </p>
  </Section>

  <Section id="features-title" title="Product core feature" dense>
    <p class="article__section-copy article__section-copy--start">
      DonAid's main scope is to verify a donation after the transaction and
      track the money received from a campaign partner to the auditing trustee
      and finally released to the charity.
    </p>
    <MediaFigure
      figure={donaid.blueprintFigure}
      titleSuffix=":"
      class="media-card--blueprint"
    />
    <div class="feature-list">
      {
        donaid.features.map((feature) => (
          <article class="feature-list__item">
            <p class="feature-list__label">{feature.label}</p>
            <div class="feature-list__copy">
              <h3 class="feature-list__title">{feature.title}</h3>
              <p class="feature-list__body">{feature.body}</p>
            </div>
            <LightboxImage
              image={feature.image}
              label={feature.title}
              wrapperClass="feature-list__image-trigger"
              imageClass="feature-list__image"
              loading="lazy"
              decoding="async"
            />
          </article>
        ))
      }
    </div>
  </Section>

  <Section id="outcome-title" title="Outcome" dense>
    <p class="article__section-copy article__section-copy--start">
      The final delivery hit a foreseeable delay for the bank integration scope
      since the founder and the team had agreed to push ahead despite the flag
      to omit it.
    </p>
    <MediaFigure
      figure={donaid.outcomeFigure}
      titleSuffix=":"
      class="media-card--outcome"
    />
    <p class="article__pull-quote">
      After the demo deployment, the founder and I had conducted a market-fit
      demonstration. <strong>All 32 attendants</strong> from various
      <strong>charity organisations expressed interest</strong> in the product and
      demonstrated a <strong>thorough understanding</strong> how donation tracking
      works.
    </p>
  </Section>

  <Section
    id="insights-title"
    title="Insights"
    class="article-section--insights"
  >
    <InsightList insights={donaid.insights} />
  </Section>

  <Footer next={nextShowcase} previous={previousShowcase} />
</Shell>

<style is:global>
  .article__media-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;

    @media (min-width: 64rem) {
      grid-column: 1 / -1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }
  }

  .article__media-grid--workshop {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .article .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    @media (min-width: 64rem) {
      grid-column: 1 / -1;
      display: flex;
      gap: 5rem;
      padding-top: 2.25rem;
    }
  }

  .article .feature-list__item {
    display: grid;
    grid-template-columns: 0.5rem minmax(0, 1.35fr) minmax(5.5rem, 0.65fr);
    gap: 0.75rem;
    align-items: start;
    padding-block: 0.75rem;

    @media (min-width: 64rem) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
      padding-block: 0;
      align-items: center;
    }
  }

  .article .feature-list__label {
    width: max-content;
    color: var(--read-low);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    transform: rotate(-90deg) translateX(-100%);
    transform-origin: left top;

    @media (min-width: 64rem) {
      display: none;
      font-size: 1.25rem;
      letter-spacing: 0.03em;
    }
  }

  .article .feature-list__copy {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    @media (min-width: 64rem) {
      gap: 1rem;
    }
  }

  .article .feature-list__title {
    color: var(--read-higher);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1;

    @media (min-width: 64rem) {
      font-size: 1.5rem;
    }
  }

  .article .feature-list__body {
    color: var(--read-low);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    line-height: 1.25;

    @media (min-width: 64rem) {
      color: var(--read-default);
      font-size: 1.25rem;
      line-height: 1.35;
    }
  }

  .article .feature-list__image-trigger {
    width: 100%;
    align-self: start;

    @media (min-width: 64rem) {
      grid-column: 2;
      justify-self: center;
      width: min(100%, 35rem);
    }
  }

  .article .feature-list__image {
    width: 100%;
    height: auto;
    background: var(--media-surface);
    opacity: 0.9;

    @media (min-width: 64rem) {
      height: auto;
    }
  }

  .article__pull-quote {
    padding-block: 0.75rem;
    color: var(--read-low);
    font-size: 1rem;
    line-height: 1.15;

    @media (min-width: 64rem) {
      grid-column: 1 / span 2;
      padding-block: 0;
      color: var(--read-default);
      font-size: 1.875rem;
      line-height: 1.25;
    }
  }

  .article-section--insights {
    padding-top: 1.5rem;

    @media (min-width: 64rem) {
      padding-top: 6rem;
    }
  }

  .article__media-grid--two-column {
    @media (min-width: 64rem) {
      grid-column: 2 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .article .feature-list__item:nth-child(2) .feature-list__copy {
    @media (min-width: 64rem) {
      grid-column: 1;
      grid-row: 1;
      text-align: right;
    }
  }

  .article .feature-list__item:nth-child(1) .feature-list__copy {
    @media (min-width: 64rem) {
      grid-column: 3;
      grid-row: 1;
    }
  }

  .article .feature-list__item:nth-child(3) .feature-list__copy {
    @media (min-width: 64rem) {
      grid-column: 3;
      grid-row: 1;
    }
  }
</style>
