---
import ArticleFooter from "@/components/article/ArticleFooter.astro";
import ArticleHeader from "@/components/article/ArticleHeader.astro";
import ArticleHero from "@/components/article/ArticleHero.astro";
import ArticleSection from "@/components/article/ArticleSection.astro";
import ArticleShell from "@/components/article/ArticleShell.astro";
import BackgroundMeta from "@/components/article/BackgroundMeta.astro";
import FeatureList from "@/components/article/FeatureList.astro";
import InsightList from "@/components/article/InsightList.astro";
import MediaFigure from "@/components/article/MediaFigure.astro";
import NumberedList from "@/components/article/NumberedList.astro";
import {
  donaidFeatures,
  donaidFeasibilityFigures,
  donaidInsights,
  donaidProblems,
  donaidProcessFigures,
  donaidWorkshopFigures,
} from "@/data/donaid";
import donaidMark from "@/graphics/donaid.svg";
import heroImage from "@/images/donaid/hero.jpg";
import wireframesImage from "@/images/donaid/wireframes.jpg";
import blueprintImage from "@/images/donaid/blueprint.jpg";
import outcomeImage from "@/images/donaid/outcome.jpg";

const backgroundMeta = [
  {
    label: "Role",
    body: "Product strategy, service design, user experience, interface design, product management",
  },
  {
    label: "Tech",
    body: "Confluence, Jira, Figma, Tailwind CSS, Next.js, Prisma, PostgreSQL, AWS",
  },
];

const interfaceFigure = {
  image: wireframesImage,
  title: "Sketching wireframes",
  body: "Wireframes helped translate the product logic into screens the team could estimate, build, and critique.",
};

const blueprintFigure = {
  image: blueprintImage,
  title: "Service blueprint",
  body: "Aligning teams and stakeholders for what DonAid is",
};

const outcomeFigure = {
  image: outcomeImage,
  title: "Demo homepage",
  body: "Five demo sites for different types of donation collection by partnership",
};

const nextShowcase = {
  href: "/wishful-menu",
  showcaseNumber: 3,
  showcaseTotal: 3,
  brand: "Wishful Menu",
  title: "Democracy in menu planning at a restaurant",
};
---

<ArticleShell title="DonAid - Firas Razak">
  <ArticleHeader />

  <ArticleHero
    showcaseNumber={2}
    showcaseTotal={3}
    title="Donation tracking & audit conceptualised"
    heroImage={heroImage}
    markImage={donaidMark}
    markAlt="DonAid"
    viewTransitionName="donaid"
  >
    <Fragment slot="summary">
      <p>
        <strong>Public trust in charitable giving</strong> is often shaken by concerns
        over fraud, misuse of funds, and opaque money handling. These issues can <strong
          >turn an act of goodwill into a leap of faith</strong
        >
        for donors.
      </p>
      <p>
        By making <strong>donation traceable, like parcel tracking</strong>,
        donors and partners can see how money moves from collection to charity.
      </p>
    </Fragment>
  </ArticleHero>

  <ArticleSection
    id="background-title"
    title="Background"
    class="background"
    titleOffset
    alignStart
  >
    <BackgroundMeta
      body="3 development attempts had failed, and other prospective agencies were unresponsive. Without a clear specification, previous teams were forced to guess, often mistaking the donation tracking system for a standard donation platform. The issue was in comprehension, not engineering."
      meta={backgroundMeta}
    />
  </ArticleSection>

  <ArticleSection id="problems-title" title="Problems">
    <NumberedList items={donaidProblems} />
  </ArticleSection>

  <ArticleSection
    id="workshop-title"
    title="Product workshop"
    dense
    titleOffset
    alignStart
  >
    <p class="section-copy">
      To start, I ran daily sessions with the founder until we reached enough
      shared understanding of the product. I then simplified the original
      material into a 7-page product brief to be sent to development agencies
      for quotation. After the rewrite,
      <strong>agency response rate increased from 10% to 80%.</strong>
    </p>
    <div class="media-grid workshop-grid">
      {donaidWorkshopFigures.map((figure) => <MediaFigure figure={figure} />)}
    </div>
  </ArticleSection>

  <ArticleSection
    id="feasibility-title"
    title="Feasibility study"
    dense
    titleOffset
    alignStart
  >
    <p class="section-copy">
      I surveyed banking and messaging integrations to map what could be
      automated, what needed vendor buy-in, and what required a manual fallback.
      Where banks moved too slow, I proposed processing the banking side
      manually as an interim workaround.
    </p>
    <div class="media-grid two-col">
      {
        donaidFeasibilityFigures.map((figure) => (
          <MediaFigure figure={figure} />
        ))
      }
    </div>
  </ArticleSection>

  <ArticleSection
    id="process-title"
    title="Work scoping"
    dense
    titleOffset
    alignStart
  >
    <p class="section-copy">
      I split the brief into domains, MVP and post-launch scope to keep the
      product coherent while the technical team estimated effort and risk.
    </p>
    <div class="media-grid process-grid two-col">
      {
        donaidProcessFigures.map((figure) => (
          <MediaFigure figure={figure} titleSuffix=":" />
        ))
      }
    </div>
  </ArticleSection>

  <ArticleSection
    id="interface-title"
    title="Interface design"
    class="interface-design"
  >
    <p class="section-copy start">
      Design was not in the agency's scope. I stepped in and delivered
      wireframes and flow diagrams to meet both stakeholder needs and technical
      constraints.
    </p>
    <MediaFigure
      figure={interfaceFigure}
      titleSuffix=":"
      class="interface-figure"
    />
  </ArticleSection>

  <ArticleSection
    id="checkins-title"
    title="Engineering check-ins"
    titleOffset
    alignStart
  >
    <p class="section-copy">
      I ran weekly check-ins, taking progress reports from the dev team while
      handing over design for the next task. I bridged the founder and dev
      across system design, business logic, architecture, and acceptance
      criteria.
    </p>
  </ArticleSection>

  <ArticleSection id="features-title" title="Product core feature" dense>
    <p class="section-copy start">
      DonAid's main scope is to verify a donation after the transaction and
      track the money received from a campaign partner to the auditing trustee
      and finally released to the charity.
    </p>
    <MediaFigure figure={blueprintFigure} titleSuffix=":" class="blueprint" />
    <FeatureList features={donaidFeatures} />
  </ArticleSection>

  <ArticleSection id="outcome-title" title="Outcome" dense>
    <p class="section-copy start">
      The final delivery hit a foreseeable delay for the bank integration scope
      since the founder and the team had agreed to push ahead despite the flag
      to omit it.
    </p>
    <MediaFigure figure={outcomeFigure} titleSuffix=":" class="outcome-card" />
    <p class="pull-quote">
      After the demo deployment, the founder and I had conducted a market-fit
      demonstration. <strong>All 32 attendants</strong> from various
      <strong>charity organisations expressed interest</strong> in the product and
      demonstrated a <strong>thorough understanding</strong> of how donation tracking
      works.
    </p>
  </ArticleSection>

  <ArticleSection id="insights-title" title="Insights" class="insights">
    <InsightList insights={donaidInsights} />
  </ArticleSection>

  <ArticleFooter next={nextShowcase} />
</ArticleShell>
