---
import type { ArticleMetaItem } from "@/types/article";

type Props = {
  meta: ArticleMetaItem[];
};

const { meta } = Astro.props;
---

<div class="background-grid">
  <p class="section-copy">
    <slot />
  </p>
  {
    meta.map((item) => (
      <p class="mini-meta">
        <strong>{item.label}</strong>
        {item.body}
      </p>
    ))
  }
</div>

<style>
  .background-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem 0.75rem;
  }

  .background-grid .section-copy {
    grid-column: 1 / -1;
  }

  .mini-meta {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    color: var(--text-muted);
    font-size: 0.625rem;
    letter-spacing: 0.03em;
    line-height: 1.35;
  }

  @media (min-width: 64rem) {
    .background-grid {
      display: contents;
    }

    .mini-meta {
      gap: 0.25rem;
      font-size: 1.25rem;
      letter-spacing: 0.03em;
      line-height: 1.35;
    }

    .mini-meta:nth-of-type(2) {
      grid-column: 2;
    }

    .mini-meta:nth-of-type(3) {
      grid-column: 3;
    }
  }
</style>
