---
type Props = {
  id: string;
  title: string;
  dense?: boolean;
  titleOffset?: boolean;
  alignStart?: boolean;
  class?: string;
};

const {
  id,
  title,
  dense = false,
  titleOffset = false,
  alignStart = false,
  class: className,
} = Astro.props;
---

<section
  class:list={[
    "case-section",
    dense && "dense-section",
    titleOffset && "title-offset",
    alignStart && "align-start",
    className,
  ]}
  aria-labelledby={id}
>
  <h2 id={id}>{title}</h2>
  <slot />
</section>

<style>
  h2 {
    color: var(--text-strong);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1;
  }

  .case-section {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    padding: 1.875rem var(--px);
  }

  .case-section.dense-section {
    padding-block: 0.75rem;
  }

  @media (min-width: 64rem) {
    h2 {
      grid-column: 1 / -1;
      font-size: 3rem;
    }

    .case-section {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2.25rem 1.5rem;
      padding: 6rem var(--px);
    }

    .case-section.title-offset > h2 {
      grid-column: 2 / -1;
    }

    .case-section.align-start {
      align-items: start;
    }

    .case-section.dense-section {
      padding-block: 6rem;
    }
  }
</style>
