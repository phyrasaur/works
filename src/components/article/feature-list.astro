---
import type { Feature } from "@/types/article";

type Props = {
  features: Feature[];
};

const { features } = Astro.props;
---

<div class="feature-list">
  {
    features.map((feature) => (
      <article class="feature-list__item">
        <p class="feature-list__label">{feature.label}</p>
        <div class="feature-list__copy">
          <h3 class="feature-list__title">{feature.title}</h3>
          <p class="feature-list__body">{feature.body}</p>
        </div>
        <img
          class="feature-list__image"
          src={feature.image.src}
          width={feature.image.width}
          height={feature.image.height}
          alt=""
          loading="lazy"
          decoding="async"
        />
      </article>
    ))
  }
</div>

<style>
  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    @media (min-width: 64rem) {
      grid-column: 1 / -1;
      display: flex;
      gap: 5rem;
      padding-top: 2.25rem;
    }

    & .feature-list__item {
      display: grid;
      grid-template-columns: 0.5rem minmax(0, 1.35fr) minmax(5.5rem, 0.65fr);
      gap: 0.75rem;
      align-items: start;
      padding-block: 0.75rem;

      @media (min-width: 64rem) {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.5rem;
        padding-block: 0;
        align-items: center;
      }

      &:nth-child(2) .feature-list__copy {
        @media (min-width: 64rem) {
          grid-column: 1;
          grid-row: 1;
          text-align: right;
        }
      }

      &:nth-child(1) .feature-list__copy,
      &:nth-child(3) .feature-list__copy {
        @media (min-width: 64rem) {
          grid-column: 3;
          grid-row: 1;
        }
      }
    }

    & .feature-list__label {
      width: max-content;
      color: var(--text-muted);
      font-size: 0.5rem;
      letter-spacing: 0.1em;
      line-height: 1;
      text-transform: uppercase;
      transform: rotate(-90deg) translateX(-100%);
      transform-origin: left top;

      @media (min-width: 64rem) {
        display: none;
        font-size: 1.25rem;
        letter-spacing: 0.03em;
      }
    }

    & .feature-list__copy {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;

      @media (min-width: 64rem) {
        gap: 1rem;
      }
    }

    & .feature-list__title {
      color: var(--text-strong);
      font-size: 1rem;
      font-weight: 400;
      line-height: 1;

      @media (min-width: 64rem) {
        font-size: 1.5rem;
      }
    }

    & .feature-list__body {
      color: var(--text-muted);
      font-size: 0.75rem;
      letter-spacing: 0.03em;
      line-height: 1.25;

      @media (min-width: 64rem) {
        color: var(--text-normal);
        font-size: 1.25rem;
        line-height: 1.35;
      }
    }

    & .feature-list__image {
      width: 100%;
      height: auto;
      align-self: start;
      opacity: 0.9;

      @media (min-width: 64rem) {
        grid-column: 2;
        justify-self: center;
        width: min(100%, 35rem);
        height: auto;
      }
    }
  }
</style>
