---
import ThemePicture from "@/components/theme-picture.astro";
import ShowcaseMark from "@/components/showcase-mark.astro";
import type { ShowcaseDetails } from "@/types/showcase";

type Props = {
  showcase: ShowcaseDetails;
  headingId?: string;
};

const { showcase, headingId = "page-title" } = Astro.props;

const { item } = showcase;
---

<section class="article-hero" aria-labelledby={headingId}>
  <hgroup>
    <p class="article-hero__kicker">
      <span>{`Showcase ${showcase.number}`}</span>
      <span>{`/ ${showcase.total}`}</span>
    </p>
    <h1 id={headingId} class="article-hero__title">{item.title}</h1>
  </hgroup>
  <figure class="article-hero__figure">
    <ThemePicture
      class="article-hero__image"
      image={item.image}
      alt=""
      decoding="async"
      priority
      style={`view-transition-name: ${item.slug}`}
    />
    <figcaption class="article-hero__caption">
      <ShowcaseMark slug={item.slug} title={item.brand} />
    </figcaption>
  </figure>
  <div class="article-hero__lede">
    <p class="article-hero__lede-title">Summary</p>
    <slot name="summary" />
  </div>
</section>

<style>
  .article-hero {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    padding-inline: var(--px);

    @media (min-width: 64rem) {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.75rem 1.5rem;
      padding: 0 var(--px);
      grid-template-rows: auto auto 1fr;
    }
  }

  .article-hero hgroup .article-hero__kicker {
    display: inline-flex;
    gap: 0.25rem;
    color: var(--read-low);
    font-size: 0.8em;
    font-weight: 600;
    line-height: 1;
    margin-bottom: 1em;

    @media (min-width: 64rem) {
      font-size: 0.6em;
    }
  }

  .article-hero hgroup .article-hero__kicker span + span {
    color: var(--read-lowest);
  }

  .article-hero hgroup .article-hero__title {
    color: var(--read-default);
    font-weight: 400;
    line-height: 1;
    max-width: 60ch;

    @media (min-width: 64rem) {
      text-wrap: balance;
    }
  }

  .article-hero__figure {
    position: relative;
    overflow: hidden;
    height: 30lvh;
    background: var(--media-surface);
    display: grid;

    @media (min-width: 64rem) {
      grid-column: 1 / -1;
      height: auto;
      margin-top: 1.75rem;
      aspect-ratio: 1728 / 723;
    }
  }

  .article-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .article-hero__caption {
    position: absolute;
    z-index: 1;
    inset: 0;
    display: grid;
  }

  .article-hero__lede {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--read-low);
    font-size: 0.875rem;
    line-height: 1.35;

    @media (min-width: 64rem) {
      font-size: 1.25rem;
      grid-column: 1 / span 2;
      grid-row: 2;
      gap: 1rem;
    }

    @media (min-width: 80rem) {
      gap: 1.75rem;
      grid-column: 3;
      grid-row: 1 / span 3;
      color: var(--read-highest);
      font-size: 1.25rem;
      letter-spacing: 0.03em;
      line-height: 1.41;
    }
  }

  .article-hero__lede-title {
    display: none;

    @media (min-width: 80rem) {
      display: block;
      color: var(--read-higher);
      font-size: 1.5rem;
      font-weight: 500;
      letter-spacing: 0;
      line-height: 1;
    }
  }

  .article-hero hgroup {
    @media (min-width: 64rem) {
      font-size: clamp(1.5rem, 2.5vw, 3rem);
      grid-column: 1 / span 2;
    }
  }
</style>
