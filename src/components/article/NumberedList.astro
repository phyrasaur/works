---
import type { ArticleNumberedItem } from "@/types/article";

type Props = {
  items: ArticleNumberedItem[];
};

const { items } = Astro.props;
---

<div class="numbered-list">
  {
    items.map((item) => (
      <article class="numbered-row">
        <p class="side-label">{item.label}</p>
        <p>
          <strong>{item.title}</strong> {item.body}
        </p>
      </article>
    ))
  }
</div>

<style>
  .numbered-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .numbered-row {
    display: grid;
    grid-template-columns: 0.5rem minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
  }

  .side-label {
    width: max-content;
    color: var(--text-muted);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    transform: rotate(-90deg) translateX(-100%);
    transform-origin: left top;
  }

  .numbered-row > p:last-child {
    color: var(--text-muted);
    font-size: 0.75rem;
    line-height: 1.25;
  }

  @media (min-width: 64rem) {
    .numbered-list {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
    }

    .numbered-row {
      grid-template-columns: 1.75rem minmax(0, 1fr);
      gap: 1.5rem;
      align-self: start;
    }

    .side-label {
      font-size: 1.25rem;
      letter-spacing: 0.03em;
    }

    .numbered-row > p:last-child {
      color: var(--text-normal);
      font-size: 1.875rem;
      letter-spacing: 0.03em;
      line-height: 1.25;
    }
  }
</style>
