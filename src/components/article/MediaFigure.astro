---
import type { Figure } from "@/types/article";

type Props = {
  figure: Figure;
  titleSuffix?: string;
  class?: string;
};

const { figure, titleSuffix = "", class: className } = Astro.props;
---

<figure class:list={["media-card", figure.className, className]}>
  <img
    class="media-card__image"
    src={figure.image.src}
    width={figure.image.width}
    height={figure.image.height}
    alt=""
    loading="lazy"
    decoding="async"
  />
  <figcaption class="media-card__caption">
    <strong>{figure.title}{titleSuffix}</strong>
    {" "}
    {figure.body}
  </figcaption>
</figure>

<style>
  .media-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;

    @media (min-width: 64rem) {
      gap: 0.75rem;
    }

    &.media-card--workshop-lead,
    &.media-card--workshop-detail {
      grid-column: 1 / -1;
    }

    &.media-card--blueprint,
    &.media-card--interface,
    &.media-card--outcome {
      @media (min-width: 64rem) {
        grid-column: 1 / -1;
      }
    }

    & .media-card__image {
      width: 100%;
      height: auto;
      opacity: 0.85;

      @media (min-width: 64rem) {
        opacity: 0.9;
      }
    }

    & .media-card__caption {
      color: var(--text-muted);
      font-size: 0.625rem;
      letter-spacing: 0.03em;
      line-height: 1.35;

      @media (min-width: 64rem) {
        font-size: 1.25rem;
        letter-spacing: 0.03em;
        line-height: 1.35;
      }
    }
  }

  :global(.article__media-grid--workshop) .media-card--workshop-detail {
    grid-column: span 2;

    @media (min-width: 64rem) {
      grid-column: 2 / -1;
    }
  }

  :global(.article__media-grid--workshop) .media-card--workshop-lead {
    @media (min-width: 64rem) {
      grid-column: 1;
    }
  }
</style>
