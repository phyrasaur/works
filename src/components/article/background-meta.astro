---
import type { MetaItem } from "@/types/article";

type Props = {
  meta: MetaItem[];
};

const { meta } = Astro.props;
---

<div class="background-meta">
  <p class="article__section-copy background-meta__copy">
    <slot />
  </p>
  {
    meta.map((item) => (
      <p class="background-meta__item">
        <strong>{item.label}</strong>
        {item.body}
      </p>
    ))
  }
</div>

<style>
  .background-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem 0.75rem;

    @media (min-width: 64rem) {
      display: contents;
    }

    & .background-meta__copy {
      grid-column: 1 / -1;
      max-width: 56ch;
    }

    & .background-meta__item {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      color: var(--text-muted);
      font-size: 0.625rem;
      letter-spacing: 0.03em;
      line-height: 1.35;

      @media (min-width: 64rem) {
        gap: 0.25rem;
        font-size: 1.25rem;
        letter-spacing: 0.03em;
        line-height: 1.35;
      }

      &:nth-of-type(2) {
        @media (min-width: 64rem) {
          grid-column: 2;
        }
      }

      &:nth-of-type(3) {
        @media (min-width: 64rem) {
          grid-column: 3;
        }
      }
    }
  }
</style>
