---
import Logo from "@/graphics/waf.svg";
import type { ShowcaseLink } from "@/types/article";

type Props = {
  next: ShowcaseLink;
  previous: ShowcaseLink;
};

const { next, previous } = Astro.props;
const previousLabel =
  previous.showcaseNumber === previous.showcaseTotal ? "Last" : "Previous";
const nextLabel = next.showcaseNumber === 1 ? "First" : "Next";
---

<footer id="next-showcase" class="article-footer">
  <a
    class="article-footer__previous"
    href={previous.href}
    aria-label={`${previousLabel} case study: ${previous.brand}`}
  >
    <span class="article-footer__kicker">
      <span>{`${previousLabel} ${previous.showcaseNumber}`}</span>
      <span>{`/ ${previous.showcaseTotal}`}</span>
    </span>
    <strong class="article-footer__brand">{previous.brand}</strong>
    <span class="article-footer__title-row">
      <span class="article-footer__previous-icon" aria-hidden="true">
        <Logo />
      </span>
      <span class="article-footer__title">{previous.title}</span>
    </span>
  </a>
  <a
    class="article-footer__next"
    href={next.href}
    aria-label={`${nextLabel} case study: ${next.brand}`}
  >
    <span class="article-footer__kicker">
      <span>{`${next.showcaseNumber}/${next.showcaseTotal}`}</span>
      <span>{nextLabel}</span>
    </span>
    <strong class="article-footer__brand">{next.brand}</strong>
    <span class="article-footer__title-row">
      <span class="article-footer__title">{next.title}</span>
      <span class="article-footer__next-icon" aria-hidden="true">
        <Logo />
      </span>
    </span>
  </a>
  <nav class="article-footer__links" aria-label="Contact links">
    <a href="/resume.pdf">resume.pdf</a>
    <a href="https://www.linkedin.com/in/firasrazak/">@firasrazak</a>
    <a href="mailto:hi@firas.works">hi@firas.works</a>
  </nav>
</footer>

<style>
  .article-footer {
    --footer-icon-offset: calc(var(--px) / 4);

    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    grid-template-rows: minmax(0, 1fr) auto;
    row-gap: var(--py);
    column-gap: 0.5rem;
    width: 100%;
    min-height: 100svh;
    padding: var(--py) var(--px);
    scroll-margin-top: 5rem;
    color: var(--text-strong);

    @media (min-width: 64rem) {
      --footer-icon-offset: calc(var(--px) / 6);

      grid-template-columns: repeat(3, minmax(0, 1fr));
      row-gap: var(--py);
      column-gap: 1.5rem;
      padding: var(--py) var(--px);
      align-items: end;
    }

    & .article-footer__previous {
      grid-column: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      align-self: center;
      color: var(--text-normal);
      font-size: 1rem;
      line-height: 1.5;
      text-align: left;

      @media (min-width: 64rem) {
        font-size: clamp(1.5rem, 2.5vw, 3rem);
      }
    }

    & .article-footer__next {
      grid-column: 2;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      align-self: center;
      color: var(--text-normal);
      font-size: 1rem;
      line-height: 1.5;
      text-align: right;

      @media (min-width: 64rem) {
        grid-column: 3;
        font-size: clamp(1.5rem, 2.5vw, 3rem);
      }
    }

    & .article-footer__next .article-footer__kicker {
      transform: rotate(180deg);
    }

    & .article-footer__kicker {
      display: inline-flex;
      gap: 0.25rem;
      writing-mode: vertical-rl;
      color: var(--text-muted);
      font-size: 0.75rem;
      font-weight: 600;
      line-height: 1;
      margin-bottom: 1em;

      & span + span {
        color: var(--text-dim);
      }

      @media (min-width: 64rem) {
        font-size: 0.6em;
      }
    }

    & .article-footer__brand {
      color: var(--text-muted);
      font-size: 0.75rem;
      font-weight: 400;

      @media (min-width: 64rem) {
        font-size: 0.8em;
      }
    }

    & .article-footer__title-row {
      align-self: stretch;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.5rem;
      align-items: start;
      position: relative;
    }

    & .article-footer__previous-icon {
      display: inline-flex;
      position: absolute;
      inset-inline-end: calc(100% + var(--footer-icon-offset));
      color: var(--text-strong);

      & :global(.logo) {
        width: 0.625rem;
        height: auto;
        transform: translateY(100%) rotate(-45deg);
      }

      @media (min-width: 64rem) {
        width: 1rem;

        & :global(.logo) {
          width: 0.75rem;
        }
      }
    }

    & .article-footer__title {
      display: block;
      max-width: 60ch;
      font-size: inherit;
      line-height: 1;
    }

    & .article-footer__next-icon {
      display: inline-flex;
      position: absolute;
      inset-inline-start: calc(100% + var(--footer-icon-offset));
      color: var(--text-strong);

      & :global(.logo) {
        width: 0.625rem;
        height: auto;
        transform: translateY(100%) rotate(135deg);
      }

      @media (min-width: 64rem) {
        width: 1rem;

        & :global(.logo) {
          width: 0.75rem;
        }
      }
    }

    & .article-footer__links {
      grid-column: 1 / -1;
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      color: var(--text-strong);
      font-size: 0.75rem;

      @media (min-width: 64rem) {
        grid-column: 1 / -1;
        font-size: 1.25rem;
      }
    }

    & .article-footer__previous .article-footer__title {
      text-align: left;
    }

    & .article-footer__previous .article-footer__title-row {
      @media (min-width: 64rem) {
        margin-inline-start: -1.25rem;
        padding-inline-start: 1.25rem;
      }
    }

    & .article-footer__next .article-footer__title {
      justify-self: end;
      text-align: right;
    }

    & .article-footer__next .article-footer__title-row {
      @media (min-width: 64rem) {
        margin-inline-end: -1.25rem;
        padding-inline-end: 1.25rem;
      }
    }
  }
</style>
