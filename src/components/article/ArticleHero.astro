---
import type { ShowcaseDetails } from "@/types/showcase";

type Props = {
  showcase: ShowcaseDetails;
  headingId?: string;
};

const { showcase, headingId = "page-title" } = Astro.props;

const { item } = showcase;
---

<section class="article-hero" aria-labelledby={headingId}>
  <p class="article-hero__kicker">
    <span>{`Showcase ${showcase.number}`}</span>
    <span>{`/ ${showcase.total}`}</span>
  </p>
  <h1 id={headingId} class="article-hero__title">{item.title}</h1>
  <figure class="article-hero__figure">
    <img
      class="article-hero__image"
      src={item.image.src}
      width={item.image.width}
      height={item.image.height}
      alt=""
      decoding="async"
      style={`view-transition-name: ${item.slug}`}
    />
    <figcaption class="article-hero__caption">
      <img
        class="article-hero__mark"
        src={item.markImage.src}
        width={item.markImage.width}
        height={item.markImage.height}
        alt={item.brand}
      />
    </figcaption>
  </figure>
  <div class="article-hero__lede">
    <p class="article-hero__lede-title">Summary</p>
    <slot name="summary" />
  </div>
</section>

<style>
  .article-hero {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    padding-inline: var(--px);

    @media (min-width: 64rem) {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-template-rows: auto auto 1fr;
      gap: 1.75rem 1.5rem;
      padding: 0 var(--px);
    }

    & .article-hero__kicker {
      display: inline-flex;
      gap: 0.25rem;
      color: var(--text-muted);
      font-size: 0.75rem;
      font-weight: 600;
      line-height: 1;

      & span + span {
        color: var(--text-dim);
      }

      @media (min-width: 64rem) {
        grid-column: 1 / span 2;
        font-size: 1.5rem;
      }
    }

    & .article-hero__title {
      color: var(--text-normal);
      font-size: clamp(1.5rem, 5vw, 4rem);
      font-weight: 400;
      line-height: 1;
      max-width: 56ch;

      @media (min-width: 64rem) {
        grid-column: 1 / span 2;
        text-wrap: balance;
      }
    }

    & .article-hero__figure {
      position: relative;
      overflow: hidden;
      height: 30lvh;
      background: #111;
      display: grid;

      @media (min-width: 64rem) {
        grid-column: 1 / -1;
        height: auto;
        margin-top: 1.75rem;
        aspect-ratio: 1728 / 723;
      }
    }

    & .article-hero__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.3;
    }

    & .article-hero__caption {
      position: absolute;
      z-index: 1;
      inset: 0;
      display: grid;

      & img {
        place-self: center;
        max-width: 35%;

        @media (min-width: 64rem) {
          max-width: 15%;
        }
      }
    }

    & .article-hero__mark {
      width: 8.25rem;
      height: 3rem;
      object-fit: contain;

      @media (min-width: 64rem) {
        width: 27.5rem;
        height: 10rem;
      }
    }

    & .article-hero__lede {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      color: var(--text-muted);
      font-size: 0.875rem;
      line-height: 1.25;

      @media (min-width: 64rem) {
        grid-column: 3;
        grid-row: 1 / span 3;
        gap: 1.75rem;
        color: #fff;
        font-size: 1.25rem;
        letter-spacing: 0.03em;
        line-height: 1.41;
      }
    }

    & .article-hero__lede-title {
      display: none;

      @media (min-width: 64rem) {
        display: block;
        color: var(--text-strong);
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: 0;
        line-height: 1;
      }
    }
  }
</style>
