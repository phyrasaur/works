---
import type { ShowcaseDetails } from "@/types/showcase";

type Props = {
  showcase: ShowcaseDetails;
  overlayOpacity?: number;
  headingId?: string;
};

const {
  showcase,
  overlayOpacity = 0.59,
  headingId = "page-title",
} = Astro.props;

const { item } = showcase;
---

<section class="preview" aria-labelledby={headingId}>
  <p class="kicker">
    <span>{`Showcase ${showcase.number}`}</span>
    <span>{`/ ${showcase.total}`}</span>
  </p>
  <h1 id={headingId}>{item.title}</h1>
  <figure class="hero-figure" style={`--hero-overlay-opacity: ${overlayOpacity}`}>
    <img
      src={item.image.src}
      width={item.image.width}
      height={item.image.height}
      alt=""
      decoding="async"
      style={`view-transition-name: ${item.slug}`}
    />
    <figcaption>
      <img
        class="hero-mark"
        src={item.markImage.src}
        width={item.markImage.width}
        height={item.markImage.height}
        alt={item.brand}
      />
    </figcaption>
  </figure>
  <div class="lede">
    <p class="lede-title">Summary</p>
    <slot name="summary" />
  </div>
</section>

<style>
  .kicker {
    display: inline-flex;
    gap: 0.25rem;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
  }

  .kicker span + span {
    color: var(--text-dim);
  }

  h1 {
    max-width: 18rem;
    color: var(--text-strong);
    font-size: 1.75rem;
    font-weight: 400;
    line-height: 1;
  }

  .preview {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    padding-inline: var(--px);
  }

  .hero-figure {
    position: relative;
    overflow: hidden;
    aspect-ratio: 312 / 185;
    background: #111;
  }

  .hero-figure::after {
    content: "";
    position: absolute;
    inset: 0;
    background: #000;
    opacity: var(--hero-overlay-opacity, 0.59);
  }

  .hero-figure > img {
    width: 100%;
    height: 128%;
    object-fit: cover;
    transform: translateY(-11%);
  }

  .hero-figure figcaption {
    position: absolute;
    z-index: 1;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%);
  }

  .hero-mark {
    width: 8.25rem;
    height: 3rem;
    object-fit: contain;
  }

  .lede {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.25;
  }

  .lede-title {
    display: none;
  }

  @media (min-width: 64rem) {
    .kicker {
      grid-column: 1 / span 2;
      font-size: 1.5rem;
    }

    h1 {
      grid-column: 1 / span 2;
      max-width: 56.25rem;
      font-size: 4rem;
    }

    .preview {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.75rem 1.5rem;
      padding: 0 var(--px);
    }

    .hero-figure {
      grid-column: 1 / -1;
      height: auto;
      margin-top: 1.75rem;
      aspect-ratio: 1728 / 723;
    }

    .hero-mark {
      width: 27.5rem;
      height: 10rem;
    }

    .lede {
      grid-column: 3;
      grid-row: 1 / span 2;
      gap: 1.75rem;
      color: #fff;
      font-size: 1.25rem;
      letter-spacing: 0.03em;
      line-height: 1.41;
    }

    .lede-title {
      display: block;
      color: var(--text-strong);
      font-size: 1.5rem;
      font-weight: 500;
      letter-spacing: 0;
      line-height: 1;
    }
  }
</style>
