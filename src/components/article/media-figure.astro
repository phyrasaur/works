---
import LightboxImage from "@/components/article/lightbox-image.astro";
import type { Figure } from "@/types/article";

type Props = {
  figure: Figure;
  titleSuffix?: string;
  class?: string;
};

const { figure, titleSuffix = "", class: className } = Astro.props;
---

<figure class:list={["media-card", figure.className, className]}>
  {
    "video" in figure ? (
      <video
        class="media-card__image"
        width={figure.video.width}
        height={figure.video.height}
        aria-label={`${figure.title}. Double-click or press F to view fullscreen.`}
        aria-keyshortcuts="F"
        data-fullscreen-video
        tabindex="0"
        autoplay
        muted
        loop
        playsinline
        controls
        preload="metadata"
        style={`--poster-light: url("${figure.video.poster.light.src}"); --poster-dark: url("${figure.video.poster.dark.src}")`}
      >
        {figure.video.sources.map((source) => (
          <source src={source.src} type={source.type} />
        ))}
      </video>
    ) : (
      <LightboxImage
        image={figure.image}
        label={figure.title}
        wrapperClass="media-card__image-trigger"
        imageClass="media-card__image"
        loading="lazy"
        decoding="async"
      />
    )
  }
  <figcaption class="media-card__caption">
    <strong>{figure.title}{titleSuffix}</strong>
    {" "}
    {figure.body}
  </figcaption>
</figure>

<style>
  .media-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;

    @media (min-width: 64rem) {
      gap: 0.75rem;
    }
  }

  .media-card__image {
    display: block;
    width: 100%;
    height: auto;
    background: var(--media-surface);
    opacity: 0.85;

    @media (min-width: 64rem) {
      opacity: 0.9;
    }
  }

  .media-card__image-trigger {
    width: 100%;
  }

  video.media-card__image {
    background-image: var(--poster-light);
    background-position: center;
    background-size: cover;

    @media (prefers-color-scheme: dark) {
      background-image: var(--poster-dark);
    }
  }

  .media-card__caption {
    color: var(--read-low);
    font-size: 0.625rem;
    letter-spacing: 0.03em;
    line-height: 1.35;

    @media (min-width: 64rem) {
      font-size: 1.25rem;
      letter-spacing: 0.03em;
      line-height: 1.35;
    }
  }

  .media-card--workshop-lead,
  .media-card--workshop-detail {
    grid-column: 1 / -1;
  }

  :global(.article__media-grid--workshop) .media-card--workshop-detail {
    grid-column: span 2;

    @media (min-width: 64rem) {
      grid-column: 2 / -1;
    }
  }

  .media-card--blueprint {
    @media (min-width: 64rem) {
      grid-column: 1 / -1;
    }
  }

  .media-card--interface {
    @media (min-width: 64rem) {
      grid-column: 1 / -1;
    }
  }

  .media-card--outcome {
    @media (min-width: 64rem) {
      grid-column: 1 / -1;
    }
  }

  :global(.article__media-grid--workshop) .media-card--workshop-lead {
    @media (min-width: 64rem) {
      grid-column: 1;
    }
  }
</style>
