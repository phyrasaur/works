---
import Head from "@/components/head.astro";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <Head />
    <title>{title}</title>
  </head>
  <body>
    <main class="article">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  .article {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
    max-width: var(--page-max);
    min-height: 100vh;
    margin-inline: auto;
    background: #000;
  }

  .article strong {
    color: var(--text-strong);
    font-weight: 700;
  }

  .article .section-copy {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.25;
  }

  @media (min-width: 64rem) {
    .article .section-copy {
      grid-column: 2 / -1;
      color: var(--text-normal);
      font-size: 1.875rem;
      letter-spacing: 0.03em;
      line-height: 1.25;
    }

    .article .section-copy.start {
      grid-column: 1 / span 2;
    }
  }
</style>
