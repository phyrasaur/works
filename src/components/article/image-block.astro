---
import LightboxImage from "@/components/article/lightbox-image.astro";
import type { ThemeImage } from "@/types/media";

type Props = {
  image: ThemeImage;
  label: string;
  class?: string;
};

const { image, label, class: className } = Astro.props;
---

<figure class:list={["article-image-block", className]}>
  <LightboxImage
    image={image}
    label={label}
    wrapperClass="article-image-block__trigger"
    imageClass="article-image-block__image"
    loading="lazy"
    decoding="async"
  />
</figure>

<style>
  .article-image-block {
    min-width: 0;

    @media (min-width: 64rem) {
      grid-column: 1 / -1;
    }
  }

  .article-image-block__trigger {
    width: 100%;
  }

  .article-image-block__image {
    width: 100%;
    height: auto;
    background: var(--media-surface);
    opacity: 0.85;

    @media (min-width: 64rem) {
      opacity: 0.9;
    }
  }
</style>
