---
import ThemePicture from "@/components/theme-picture.astro";
import type { ThemeImage } from "@/types/media";

type Props = {
  image: ThemeImage;
  alt?: string;
  class?: string;
};

const { image, alt = "", class: className } = Astro.props;
---

<figure class:list={["article-image-block", className]}>
  <ThemePicture
    class="article-image-block__image"
    image={image}
    alt={alt}
    loading="lazy"
    decoding="async"
  />
</figure>

<style>
  .article-image-block {
    min-width: 0;

    @media (min-width: 64rem) {
      grid-column: 1 / -1;
    }
  }

  .article-image-block__image {
    width: 100%;
    height: auto;
    background: var(--media-surface);
    opacity: 0.85;

    @media (min-width: 64rem) {
      opacity: 0.9;
    }
  }
</style>
