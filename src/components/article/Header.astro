---
import Banner from "@/components/banner.astro";

type Props = {
  closeHref?: string;
  runningTitle?: string;
  runningSubtitle?: string;
};

const {
  closeHref = "/#showcase",
  runningTitle = "Showcase",
  runningSubtitle,
} = Astro.props;
---

<Banner
  variant="article"
  heroSelector=".article-hero"
  runningTitle={runningTitle}
  runningSubtitle={runningSubtitle}
  ctaHref={closeHref}
  ctaLabel="Showcases"
  contactHref="#contact"
/>
