---
import type { ArticleFeature } from "@/types/article";

type Props = {
  features: ArticleFeature[];
};

const { features } = Astro.props;
---

<div class="feature-list">
  {
    features.map((feature) => (
      <article class="feature-row">
        <p class="side-label">{feature.label}</p>
        <div class="feature-copy">
          <h3>{feature.title}</h3>
          <p>{feature.body}</p>
        </div>
        <img
          src={feature.image.src}
          width={feature.image.width}
          height={feature.image.height}
          alt=""
          loading="lazy"
          decoding="async"
        />
      </article>
    ))
  }
</div>

<style>
  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 0.5rem minmax(0, 1.35fr) minmax(5.5rem, 0.65fr);
    gap: 0.75rem;
    align-items: start;
    padding-block: 0.75rem;
  }

  .side-label {
    width: max-content;
    color: var(--text-muted);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    transform: rotate(-90deg) translateX(-100%);
    transform-origin: left top;
  }

  .feature-copy {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  h3 {
    color: var(--text-strong);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1;
  }

  .feature-copy p {
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    line-height: 1.25;
  }

  .feature-row img {
    width: 100%;
    height: auto;
    align-self: start;
    opacity: 0.9;
  }

  @media (min-width: 64rem) {
    .feature-list {
      grid-column: 1 / -1;
      display: flex;
      gap: 5rem;
      padding-top: 2.25rem;
    }

    .feature-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
      padding-block: 0;
      align-items: center;
    }

    .side-label {
      display: none;
      font-size: 1.25rem;
      letter-spacing: 0.03em;
    }

    h3 {
      font-size: 1.5rem;
    }

    .feature-row img {
      grid-column: 2;
      justify-self: center;
      width: min(100%, 35rem);
      height: auto;
    }

    .feature-row:nth-child(2) img {
      width: 22.5rem;
    }

    .feature-row:nth-child(2) .feature-copy {
      grid-column: 1;
      grid-row: 1;
      text-align: right;
    }

    .feature-row:nth-child(1) .feature-copy,
    .feature-row:nth-child(3) .feature-copy {
      grid-column: 3;
      grid-row: 1;
    }

    .feature-copy {
      gap: 1rem;
    }

    .feature-copy p {
      color: var(--text-normal);
      font-size: 1.25rem;
      line-height: 1.35;
    }
  }
</style>
