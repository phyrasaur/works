---
import { getImage } from "astro:assets";
import type { HTMLAttributes } from "astro/types";
import type { ThemeImage } from "@/types/media";

type Props = Omit<
  HTMLAttributes<"img">,
  "src" | "srcset" | "width" | "height" | "alt"
> & {
  image: ThemeImage;
  alt: string;
  width?: number;
  height?: number;
  priority?: boolean;
};

const {
  image,
  width = image.light.width,
  height = image.light.height,
  priority = false,
  loading = priority ? "eager" : "lazy",
  decoding = priority ? "sync" : "async",
  fetchpriority = priority ? "high" : undefined,
  alt,
  class: className,
  ...attributes
} = Astro.props;

if (
  image.light.width !== image.dark.width ||
  image.light.height !== image.dark.height
) {
  throw new Error(
    `Theme image dimensions must match: ${image.light.src} and ${image.dark.src}`,
  );
}

async function resolveImage(source: ImageMetadata) {
  if (source.format === "svg") {
    return {
      src: source.src,
      srcset: source.src,
    };
  }

  const result = await getImage({
    src: source,
    width,
    height,
    format: source.format,
  });

  return {
    src: result.src,
    srcset: result.srcSet.attribute || result.src,
  };
}

const [lightImage, darkImage] = await Promise.all([
  resolveImage(image.light),
  resolveImage(image.dark),
]);
---

<picture class="theme-picture">
  <source srcset={lightImage.srcset} media="(prefers-color-scheme: light)" />
  <source srcset={darkImage.srcset} media="(prefers-color-scheme: dark)" />
  <img
    src={lightImage.src}
    width={width}
    height={height}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={className}
    {...attributes}
  />
</picture>

<style>
  .theme-picture {
    display: contents;
  }
</style>
