---
import Logo from "@/graphics/waf.svg";
import Info from "@/graphics/info.svg";
import InfoDialog from "@/components/info.astro";
---

<header class="site-banner">
  <a href="/" class="site-banner__logo-link">
    <Logo />
    <span class="sr-only">Home</span>
    <span class="site-banner__top-text" aria-hidden="true">Scroll to top</span>
  </a>

  <p class="site-banner__title" aria-hidden="true">
    Firas Razak <span class="site-banner__designation"
      >Product Design & Management</span
    >
  </p>

  <button
    type="button"
    class="site-banner__info-button"
    command="show-modal"
    commandfor="info-dialog"
    aria-haspopup="dialog"
  >
    <span>Design Squiggle</span>
    <Info />
  </button>

  <a class="site-banner__contact" href="/#contact">
    <span class="site-banner__contact-text">Contact</span>
    <Logo />
  </a>
</header>

<InfoDialog />

<style>
  .site-banner {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    padding: var(--py) var(--px);
    pointer-events: none;
    background-image: linear-gradient(
      to bottom,
      #000 0%,
      #000000c7 0%,
      #00000027 60%,
      #00000000 100%
    );

    & .site-banner__logo-link {
      justify-self: start;
      position: relative;
      display: inline-flex;
      align-items: flex-start;
      gap: 0.75rem;
      color: var(--text-strong);
      pointer-events: auto;

      & .logo {
        width: 1.25rem;
        height: auto;
        transition:
          transform 280ms ease,
          opacity 280ms ease;

        @media (min-width: 64rem) {
          width: 1.5rem;
        }
      }
    }

    & .site-banner__top-text {
      opacity: 0;
      color: var(--text-muted);
      transition: opacity 280ms ease;
    }

    & .site-banner__title {
      align-self: center;
      display: none;
      opacity: 0;
      color: var(--text-strong);
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      transition: opacity 280ms ease;

      @media (min-width: 64rem) {
        display: block;
      }
    }

    & .site-banner__designation {
      margin-inline-start: 0.25ch;
      font-weight: 400;
      color: var(--text-normal);
    }

    & .site-banner__info-button {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
      display: flex;
      flex-direction: column-reverse;
      align-items: flex-end;
      gap: 0.125rem;
      padding: 0;
      color: var(--text-strong);
      text-align: right;
      transition: opacity 300ms;
      pointer-events: auto;
      will-change: opacity;

      & span {
        max-width: 4rem;
        font-size: 0.875rem;
        line-height: 1.1;
      }

      & .info {
        width: 0.75rem;
        height: auto;
      }

      &:hover {
        color: #fff;
      }

      @media (min-width: 64rem) {
        position: static;
        flex-direction: row;
        align-items: center;
        gap: 0.5rem;
        font-size: 1rem;

        & span {
          max-width: none;
          font-size: inherit;
          line-height: 1;
        }

        & .info {
          width: 1.25rem;
        }
      }
    }

    & .site-banner__contact {
      grid-column: 3;
      grid-row: 1;
      justify-self: end;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      opacity: 0;
      pointer-events: none;
      color: var(--text-strong);
      transition:
        opacity 280ms ease,
        transform 280ms ease;
      will-change: opacity, transform;

      & .logo {
        margin-top: -0.25rem;
        width: 1rem;
        height: auto;
        transform: rotate(-135deg);
        transition:
          opacity 280ms ease,
          transform 280ms ease;
      }

      @media (min-width: 64rem) {
        position: static;
      }
    }

    &.is-past-hero {
      & .site-banner__logo-link {
        & .logo {
          transform: translateX(0.3em) rotate(45deg);
        }

        & .site-banner__top-text {
          opacity: 1;
        }
      }

      & .site-banner__title {
        opacity: 1;
      }

      & .site-banner__info-button {
        opacity: 0;
        pointer-events: none;
      }

      & .site-banner__contact {
        opacity: 1;
        pointer-events: auto;
      }
    }

    &.is-at-contact {
      & .site-banner__logo-link {
        & .logo {
          transform: translateX(0) rotate(0deg);
        }

        & .site-banner__top-text {
          opacity: 0;
        }
      }

      & .site-banner__contact {
        opacity: 0.75;
        transform: translate(1.5rem, 1rem) rotate(-90deg) scale(2);
        pointer-events: none;

        @media (min-width: 64rem) {
          opacity: 1;
          transform: translate(1.5rem, 0.25rem) rotate(0deg) scale(1);
        }

        & .logo {
          transform: rotate(-225deg);
          opacity: 0;
        }
      }
    }
  }
</style>

<script>
  const header = document.querySelector(".site-banner");
  const logoLink = document.querySelector(".site-banner__logo-link");
  const hero = document.querySelector(".hero");
  const contact = document.querySelector("#contact");

  if (header && logoLink && hero) {
    const titleObserver = new IntersectionObserver(
      ([entry]) => {
        const isPastHero = !entry.isIntersecting;
        header.classList.toggle("is-past-hero", isPastHero);
        hero.classList.toggle("is-past-hero", isPastHero);
        logoLink.setAttribute("href", isPastHero ? "#" : "/");
      },
      { rootMargin: "0px", threshold: 0.25 },
    );

    titleObserver.observe(hero);
  }

  if (header && contact) {
    const contactObserver = new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle("is-at-contact", entry.isIntersecting);
      },
      { threshold: 0.75 },
    );

    contactObserver.observe(contact);
  }

  const infoDialog = document.getElementById("info-dialog");
  document
    .querySelector(".site-banner__info-button")
    ?.addEventListener("click", () => {
      if (infoDialog instanceof HTMLDialogElement) infoDialog.showModal();
    });
</script>
