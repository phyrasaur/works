---
import Logo from "@/graphics/waf.svg";
import Info from "@/graphics/info.svg";
import InfoDialog from "@/components/info.astro";
---

<header class="banner" data-site-header>
  <a href="/" class="logo-link" data-logo-link>
    <Logo />
    <span class="sr-only">Home</span>
    <span class="top-text" aria-hidden="true">Scroll to top</span>
  </a>

  <p class="running-title" aria-hidden="true">
    Firas Razak <span class="designation">Product Design & Management</span>
  </p>

  <button
    type="button"
    class="squiggle-info-trigger"
    data-dialog-trigger="info-dialog"
    aria-haspopup="dialog"
  >
    <span>Design Squiggle</span>
    <Info />
  </button>

  <a class="contact-cta" href="/#contact">
    <span class="text">Contact</span>
    <Logo />
  </a>
</header>

<InfoDialog />

<style>
  .banner {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: start;
    padding: 1.75rem 1.25rem 3rem var(--px);
    pointer-events: none;
    background-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 34%,
      #000000b8 58%,
      #00000000 100%
    );

    & > * {
      pointer-events: auto;
    }
  }

  .logo-link {
    position: relative;
    display: inline-flex;
    align-items: flex-start;
    gap: 0.5rem;
    width: max-content;
    color: var(--text-strong);

    & .logo {
      width: 1.25rem;
      height: auto;
      transition:
        transform 280ms ease,
        opacity 280ms ease;
    }

    & .top-text {
      position: absolute;
      top: 0.15rem;
      left: 1.75rem;
      width: max-content;
      opacity: 0;
      color: var(--text-muted);
      transition: opacity 280ms ease;
    }
  }

  .running-title {
    align-self: center;
    justify-self: center;
    display: none;
    opacity: 0;
    color: var(--text-strong);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    transition: opacity 280ms ease;

    & .designation {
      margin-inline-start: 0.25ch;
      font-weight: 400;
      color: var(--text-normal);
    }
  }

  .squiggle-info-trigger {
    position: fixed;
    top: 1.75rem;
    right: 1.25rem;
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-end;
    gap: 0.125rem;
    padding: 0;
    color: var(--text-strong);
    text-align: right;
    transition:
      opacity 280ms ease,
      color 280ms ease;

    & span {
      max-width: 4rem;
      font-size: 0.875rem;
      line-height: 1.1;
    }

    & .info {
      width: 0.75rem;
      height: auto;
    }

    &:hover {
      color: #fff;
    }
  }

  .contact-cta {
    position: fixed;
    top: 1.75rem;
    right: 1.25rem;
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    pointer-events: none;
    color: var(--text-strong);
    transition:
      opacity 280ms ease,
      transform 280ms ease;

    & .logo {
      width: 1rem;
      height: auto;
      transform: rotate(-135deg);
      transition:
        opacity 280ms ease,
        transform 280ms ease;
    }
  }

  .banner.is-past-hero {
    & .logo-link {
      & .logo {
        transform: translateX(0.3em) rotate(45deg);
      }

      & .top-text {
        opacity: 1;
      }
    }

    & .running-title {
      opacity: 1;
    }

    & .squiggle-info-trigger {
      opacity: 0;
      pointer-events: none;
    }

    & .contact-cta {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .banner.is-at-contact {
    & .contact-cta {
      transform: translateX(2.125rem);

      & .logo {
        opacity: 0;
        transform: rotate(-225deg);
      }
    }
  }

  @media (min-width: 64rem) {
    .banner {
      align-items: center;
      padding: 6rem var(--px) 12rem;
      grid-template-columns: minmax(0, 1fr) minmax(0, 2fr) minmax(0, 1fr);
      mask-image: linear-gradient(to bottom, #000 72%, transparent 100%);
    }

    .logo-link .logo {
      width: 1.5rem;
    }

    .running-title {
      display: block;
    }

    .squiggle-info-trigger {
      position: static;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;

      & span {
        max-width: none;
        font-size: inherit;
        line-height: 1;
      }

      & .info {
        width: 1.25rem;
      }
    }

    .contact-cta .logo {
      width: 1.5rem;
    }

    .contact-cta {
      position: static;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .banner *,
    .banner {
      transition-duration: 1ms;
    }
  }
</style>

<script>
  const header = document.querySelector("[data-site-header]");
  const logoLink = document.querySelector("[data-logo-link]");
  const hero = document.querySelector("[data-hero]");
  const contact = document.querySelector("#contact");

  if (header && logoLink && hero) {
    const titleObserver = new IntersectionObserver(
      ([entry]) => {
        const isPastHero = !entry.isIntersecting;
        header.classList.toggle("is-past-hero", isPastHero);
        logoLink.setAttribute("href", isPastHero ? "#" : "/");
      },
      { rootMargin: "-120px" },
    );

    titleObserver.observe(hero);
  }

  if (header && contact) {
    const contactObserver = new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle("is-at-contact", entry.isIntersecting);
      },
      { threshold: 0.5 },
    );

    contactObserver.observe(contact);
  }

  document.querySelectorAll("[data-dialog-trigger]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const dialogId = trigger.getAttribute("data-dialog-trigger");
      const dialog = dialogId
        ? document.getElementById(dialogId)
        : undefined;

      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
    });
  });
</script>
