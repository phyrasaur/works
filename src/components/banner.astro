---
import Logo from "@/graphics/waf.svg";
import Info from "@/graphics/info.svg";
import InfoDialog from "@/components/info.astro";
---

<header class="banner">
  <a href="/" class="logo-link">
    <Logo />
    <span class="sr-only">Home</span>
    <span class="top-text" aria-hidden="true">Scroll to top</span>
  </a>

  <p class="running-title" aria-hidden="true">
    Firas Razak <span class="designation">Product Design & Management</span>
  </p>

  <button
    type="button"
    class="squiggle-info-trigger"
    command="show-modal"
    commandfor="info-dialog"
    aria-haspopup="dialog"
  >
    <span>Design Squiggle</span>
    <Info />
  </button>

  <a class="contact-cta" href="/#contact">
    <span class="text">Contact</span>
    <Logo />
  </a>
</header>

<InfoDialog />

<style>
  .banner {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    padding: var(--py) var(--px);
    pointer-events: none;
    background-image: linear-gradient(
      to bottom,
      #000 0%,
      #000000c7 0%,
      #00000027 60%,
      #00000000 100%
    );
  }

  .logo-link {
    justify-self: start;
    position: relative;
    display: inline-flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--text-strong);
    pointer-events: auto;
    & .logo {
      width: 1.25rem;
      height: auto;
      transition:
        transform 280ms ease,
        opacity 280ms ease;

      @media (min-width: 64rem) {
        width: 1.5rem;
      }
    }

    & .top-text {
      opacity: 0;
      color: var(--text-muted);
      transition: opacity 280ms ease;
    }
  }

  .running-title {
    align-self: center;
    display: none;
    opacity: 0;
    color: var(--text-strong);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    transition: opacity 280ms ease;

    & .designation {
      margin-inline-start: 0.25ch;
      font-weight: 400;
      color: var(--text-normal);
    }

    @media (min-width: 64rem) {
      display: block;
    }
  }

  .squiggle-info-trigger {
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-end;
    gap: 0.125rem;
    padding: 0;
    color: var(--text-strong);
    text-align: right;
    transition: opacity 300ms;
    pointer-events: auto;
    will-change: opacity;
    & span {
      max-width: 4rem;
      font-size: 0.875rem;
      line-height: 1.1;
    }

    & .info {
      width: 0.75rem;
      height: auto;
    }

    &:hover {
      color: #fff;
    }

    @media (min-width: 64rem) {
      position: static;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;

      & span {
        max-width: none;
        font-size: inherit;
        line-height: 1;
      }

      & .info {
        width: 1.25rem;
      }
    }
  }

  .contact-cta {
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    pointer-events: none;
    color: var(--text-strong);
    transition:
      opacity 280ms ease,
      transform 280ms ease;
    will-change: opacity, transform;
    & .logo {
      margin-top: -0.25rem;
      width: 1rem;
      height: auto;
      transform: rotate(-135deg);
      transition:
        opacity 280ms ease,
        transform 280ms ease;
    }

    @media (min-width: 64rem) {
      position: static;
    }
  }

  .banner.is-past-hero {
    & .logo-link {
      & .logo {
        transform: translateX(0.3em) rotate(45deg);
      }

      & .top-text {
        opacity: 1;
      }
    }

    & .running-title {
      opacity: 1;
    }

    & .squiggle-info-trigger {
      opacity: 0;
      pointer-events: none;
    }

    & .contact-cta {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .banner.is-at-contact {
    & .logo-link {
      & .logo {
        transform: translateX(0) rotate(0deg);
      }

      & .top-text {
        opacity: 0;
      }
    }
    & .contact-cta {
      opacity: 0.75;
      transform: translate(1.5rem, 1rem) rotate(-90deg) scale(2);
      pointer-events: none;
      @media (min-width: 64rem) {
        opacity: 1;
        transform: translate(1.5rem, 0.25rem) rotate(0deg) scale(1);
      }
      & .logo {
        transform: rotate(-225deg);
        opacity: 0;
      }
    }
  }
</style>

<script>
  const header = document.querySelector(".banner");
  const logoLink = document.querySelector(".logo-link");
  const hero = document.querySelector(".hero");
  const contact = document.querySelector("#contact");

  if (header && logoLink && hero) {
    const titleObserver = new IntersectionObserver(
      ([entry]) => {
        const isPastHero = !entry.isIntersecting;
        header.classList.toggle("is-past-hero", isPastHero);
        hero.classList.toggle("is-past-hero", isPastHero);
        logoLink.setAttribute("href", isPastHero ? "#" : "/");
      },
      { rootMargin: "0px", threshold: 0.25 },
    );

    titleObserver.observe(hero);
  }

  if (header && contact) {
    const contactObserver = new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle("is-at-contact", entry.isIntersecting);
      },
      { threshold: 0.75 },
    );

    contactObserver.observe(contact);
  }

  const infoDialog = document.getElementById("info-dialog");
  document
    .querySelector(".squiggle-info-trigger")
    ?.addEventListener("click", () => {
      if (infoDialog instanceof HTMLDialogElement) infoDialog.showModal();
    });
</script>
