---
import { infoContent } from "@/data/info";
---

<dialog id="info-dialog" class="info-dialog" aria-labelledby="info-title">
  <form method="dialog" class="info-dialog__panel">
    <header class="info-dialog__header">
      <h2 id="info-title">{infoContent.title}</h2>
      <button class="info-dialog__close" aria-label="Close dialog">
        <svg
          width="24"
          height="24"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </header>

    <div class="info-dialog__content">
      {infoContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </form>
</dialog>

<style>
  .info-dialog {
    box-sizing: border-box;
    inset: auto 0 0;
    width: 100%;
    max-width: none;
    height: auto;
    max-height: 100dvh;
    margin: auto 0 0;
    padding: 0;
    background: #000;
    border: 0;
    border-top: 1px solid var(--hairline);
    box-shadow: 0 -2rem 5rem #000000bf;
    overflow-y: auto;
    opacity: 0;
    color: var(--text-normal);
    transform: translateY(100%);
    transition:
      opacity 300ms ease,
      transform 300ms ease,
      overlay 300ms ease allow-discrete,
      display 300ms ease allow-discrete;

    @media (prefers-reduced-motion: reduce) {
      transition-duration: 1ms;
    }

    @media (min-width: 64rem) {
      inset: 0 0 0 auto;
      width: min(100vw, 33.75rem);
      height: 100dvh;
      max-height: none;
      margin: 0 0 0 auto;
      border-top: 0;
      border-left: 1px solid var(--hairline);
      box-shadow: -49px 0 200px 87px #000000bf;
      transform: translateX(100%);
    }
  }

  .info-dialog::backdrop {
    background: linear-gradient(to bottom, #00000031, #00000099);
    opacity: 0;
    transition: opacity 300ms ease;

    @media (prefers-reduced-motion: reduce) {
      transition-duration: 1ms;
    }

    @media (min-width: 64rem) {
      background: linear-gradient(to right, #00000012, #00000099);
    }
  }

  .info-dialog:open {
    opacity: 1;
    transform: translateY(0);

    @media (min-width: 64rem) {
      transform: translateX(0);
    }
  }

  .info-dialog:open::backdrop {
    opacity: 1;
  }

  @starting-style {
    .info-dialog:open {
      opacity: 0;
      transform: translateY(100%);
    }
  }

  @starting-style {
    .info-dialog:open::backdrop {
      opacity: 0;
    }
  }

  @media (min-width: 64rem) {
    @starting-style {
      .info-dialog:open {
        transform: translateX(100%);
      }
    }
  }

  .info-dialog__panel {
    box-sizing: border-box;
    min-height: auto;
    display: flex;
    flex-direction: column;
    gap: var(--section-gap);
    padding: var(--py) var(--px);

    @media (min-width: 64rem) {
      min-height: 100%;
    }
  }

  .info-dialog__header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .info-dialog__header h2 {
    font-size: 1.75rem;
    font-weight: 400;
    line-height: 1.1;
  }

  .info-dialog__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
  }

  .info-dialog__close:hover {
    color: #fff;
  }

  .info-dialog__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 1rem;
    letter-spacing: 0.03em;
    line-height: 1.35;

    @media (min-width: 64rem) {
      font-size: 1.25rem;
    }
  }

  .info-dialog__content p {
    max-width: 56ch;
  }
</style>

<script>
  const infoDialog = document.getElementById("info-dialog");

  if (infoDialog instanceof HTMLDialogElement) {
    infoDialog.addEventListener("click", (event) => {
      if (event.target === infoDialog) infoDialog.close();
    });
  }
</script>
