---

---

<dialog id="info-dialog" class="info-dialog" aria-labelledby="info-title">
  <form method="dialog" class="info-panel">
    <header class="info-header">
      <h2 id="info-title">Design Squiggle</h2>
      <button class="close-dialog" aria-label="Close dialog">
        <svg
          width="24"
          height="24"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </header>

    <div class="info-content">
      <p>
        The Design Squiggle by Damien Newman captures a familiar reality in
        design work. The path to a good outcome rarely looks linear. Early
        stages include uncertainty, competing signals, and imperfect first
        attempts. Over time, the work narrows toward a decision and a usable
        solution.
      </p>
      <p>
        My process fits this shape across research, strategy, systems thinking,
        interface design, and implementation. I use AI to speed up early
        exploration when the problem definition still needs work. I map
        constraints, test assumptions, and clarify what success looks like
        before committing to detailed execution. The goal stays consistent:
        reduce complexity into a direction a team can build.
      </p>
    </div>
  </form>
</dialog>

<style>
  .info-dialog {
    width: min(100vw, 33.75rem);
    max-width: none;
    height: 100dvh;
    max-height: none;
    margin: 0 0 0 auto;
    padding: 0;
    color: var(--text-strong);
    background: #000;
    border: 0;
    border-left: 1px solid var(--hairline);
    box-shadow: -49px 0 200px 87px #000000bf;
    overflow-y: auto;
    opacity: 0;
    transform: translateX(100%);
    transition:
      opacity 300ms ease,
      transform 300ms ease,
      overlay 300ms ease allow-discrete,
      display 300ms ease allow-discrete;

    &::backdrop {
      background: linear-gradient(to right, #00000012, #00000099);
      opacity: 0;
      transition: opacity 300ms ease;
    }

    &:open {
      opacity: 1;
      transform: translateX(0);

      &::backdrop {
        opacity: 1;
      }

      @starting-style {
        opacity: 0;
        transform: translateX(100%);

        &::backdrop {
          opacity: 0;
        }
      }
    }
  }

  .info-panel {
    box-sizing: border-box;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding: var(--px);
  }

  .info-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    & h2 {
      font-size: 1.25rem;
      font-weight: 400;
      line-height: 1;
    }
  }

  .close-dialog {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    color: var(--text-strong);

    &:hover {
      color: #fff;
    }
  }

  .info-content {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    color: var(--text-strong);
    font-size: clamp(1rem, 0.8rem + 0.5vw, 1.25rem);
    letter-spacing: 0.03em;
    line-height: 1.35;

    & p {
      opacity: 0.9;
    }
  }

  @media (min-width: 64rem) {
    .info-panel {
      gap: 3.5rem;
      padding: 6.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .info-dialog,
    .info-dialog::backdrop {
      transition-duration: 1ms;
    }
  }
</style>

<script>
  const infoDialog = document.getElementById("info-dialog");

  if (infoDialog instanceof HTMLDialogElement) {
    infoDialog.addEventListener("click", (event) => {
      if (event.target === infoDialog) {
        infoDialog.close();
      }
    });
  }
</script>
