---
import { infoContent } from "@/data/info";
---

<dialog id="info-dialog" class="info-dialog" aria-labelledby="info-title">
  <form method="dialog" class="info-panel">
    <header class="info-header">
      <h2 id="info-title">{infoContent.title}</h2>
      <button class="close-dialog" aria-label="Close dialog">
        <svg
          width="24"
          height="24"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </header>

    <div class="info-content">
      {infoContent.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </form>
</dialog>

<style>
  .info-dialog {
    box-sizing: border-box;
    inset: auto 0 0;
    width: 100%;
    max-width: none;
    height: auto;
    max-height: 100dvh;
    margin: auto 0 0;
    padding: 0;
    color: var(--text-strong);
    background: #000;
    border: 0;
    border-top: 1px solid var(--hairline);
    box-shadow: 0 -2rem 5rem #000000bf;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(100%);
    transition:
      opacity 300ms ease,
      transform 300ms ease,
      overlay 300ms ease allow-discrete,
      display 300ms ease allow-discrete;

    &::backdrop {
      background: linear-gradient(to bottom, #00000031, #00000099);
      opacity: 0;
      transition: opacity 300ms ease;
    }

    &:open {
      opacity: 1;
      transform: translateY(0);

      &::backdrop {
        opacity: 1;
      }

      @starting-style {
        opacity: 0;
        transform: translateY(100%);

        &::backdrop {
          opacity: 0;
        }
      }
    }

    @media (prefers-reduced-motion: reduce) {
      &,
      &::backdrop {
        transition-duration: 1ms;
      }
    }

    @media (min-width: 64rem) {
      inset: 0 0 0 auto;
      width: min(100vw, 33.75rem);
      height: 100dvh;
      max-height: none;
      margin: 0 0 0 auto;
      border-top: 0;
      border-left: 1px solid var(--hairline);
      box-shadow: -49px 0 200px 87px #000000bf;
      transform: translateX(100%);

      &::backdrop {
        background: linear-gradient(to right, #00000012, #00000099);
      }

      &:open {
        transform: translateX(0);

        @starting-style {
          transform: translateX(100%);
        }
      }
    }
  }

  .info-panel {
    box-sizing: border-box;
    min-height: auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding: var(--px);

    @media (min-width: 64rem) {
      min-height: 100%;
      gap: 3.5rem;
      padding: 6.25rem;
    }
  }

  .info-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;

    & h2 {
      font-size: 1.25rem;
      font-weight: 400;
      line-height: 1;
    }
  }

  .close-dialog {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    color: var(--text-strong);

    &:hover {
      color: #fff;
    }
  }

  .info-content {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    color: var(--text-strong);
    font-size: clamp(1rem, 0.8rem + 0.5vw, 1.25rem);
    letter-spacing: 0.03em;
    line-height: 1.35;

    & p {
      opacity: 0.9;
    }
  }
</style>

<script>
  const infoDialog = document.getElementById("info-dialog");

  if (infoDialog instanceof HTMLDialogElement) {
    infoDialog.addEventListener("click", (event) => {
      if (event.target === infoDialog) infoDialog.close();
    });
  }
</script>
