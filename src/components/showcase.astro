---
import ThemePicture from "@/components/theme-picture.astro";
import ShowcaseMark from "@/components/showcase-mark.astro";
import { showcaseItems } from "@/data/showcase";
const itemCount = showcaseItems.length;
---

<section aria-labelledby="showcase-title" id="showcase" class="showcase">
  <h2 class="sr-only" id="showcase-title">Showcase</h2>
  <ul class="showcase__list">
    {
      showcaseItems.map((item, index) => (
        <li class="showcase__item">
          <article class="showcase__card">
            <header
              class="showcase__meta showcase__meta--mobile"
              aria-label={`${item.brand} metadata`}
            >
              <p class="showcase__meta-group">
                <span class="showcase__label">Brand</span>
                <span>{item.brand}</span>
              </p>
              <p class="showcase__meta-group">
                <span class="showcase__label">Showcase</span>
                <span>{`${index + 1} / ${itemCount}`}</span>
              </p>
            </header>

            <figure class="showcase__figure">
              <ThemePicture
                class={`showcase__image showcase__image--${item.slug}`}
                image={item.image}
                alt=""
                loading="lazy"
                decoding="async"
              />
              <figcaption class={`showcase__mark showcase__mark--${item.slug}`}>
                <a
                  href={`/${item.slug}`}
                  class="showcase__mark-link"
                  aria-label={`View ${item.brand} showcase`}
                >
                  <ShowcaseMark slug={item.slug} />
                </a>
              </figcaption>
            </figure>

            <footer class="showcase__footer">
              <div class="showcase__copy">
                <h3 class="showcase__title">
                  {item.title}
                  <a href={`/${item.slug}`} class="showcase__title-link">
                    <span class="sr-only">Read showcase</span>
                    <span class="showcase__title-arrow" aria-hidden="true">
                      ›
                    </span>
                  </a>
                </h3>
                <p>{item.service}</p>
              </div>

              <p class="showcase__desktop-brand">
                <span>{item.brand}</span>
                <span class="showcase__label">Brand</span>
              </p>

              <p class="showcase__desktop-count">
                <span>{`${index + 1} / ${itemCount}`}</span>
                <span class="showcase__label">Showcase</span>
              </p>
            </footer>
          </article>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .showcase {
    scroll-margin-top: 5rem;
  }

  .showcase__list {
    display: flex;
    flex-direction: column;
    gap: var(--section-gap);
    margin: 0;
    list-style: none;
  }

  .showcase__item {
    position: relative;
  }

  .showcase__card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: var(--px);
    color: var(--read-higher);

    @media (min-width: 64rem) {
      gap: 1.5rem;
      padding: var(--py) var(--px);
    }
  }

  .showcase__meta--mobile {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;

    @media (min-width: 64rem) {
      display: none;
    }
  }

  .showcase__meta-group {
    display: grid;
    gap: 0.25rem;
  }

  .showcase__meta-group:last-child {
    text-align: end;
  }

  .showcase__label {
    font-size: 0.75rem;
    color: var(--read-lowest);
    font-weight: 500;
  }

  .showcase__figure {
    position: relative;
    height: 60lvh;
    margin: 0;
    overflow: hidden;

    @media (min-width: 64rem) {
      height: auto;
      aspect-ratio: 7 / 3;
    }
  }

  .showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .showcase__mark {
    position: absolute;
    z-index: 1;
    inset: 0;
    display: grid;
  }

  .showcase__mark-link {
    display: grid;
  }

  .showcase__footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
    font-size: clamp(1.25rem, 1.5vw, 2.5rem);

    @media (min-width: 64rem) {
      grid-template-columns: minmax(0, 1.7fr) minmax(16rem, 1fr) auto;
      gap: 0.5rem;
    }
  }

  .showcase__copy > p {
    margin-top: 0.5rem;
    color: var(--read-low);
    font-weight: 500;
    line-height: 1;
    font-size: 0.9em;

    @media (min-width: 64rem) {
      font-size: 0.75em;
    }
  }

  .showcase__title {
    color: var(--read-higher);
    font-weight: 500;
    line-height: 1.1;
    text-wrap: balance;
    position: relative;
  }

  .showcase__title:hover {
    color: var(--read-highest);
    text-decoration: underline;
  }

  .showcase__title-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .showcase__title-link:focus-visible {
    outline: none;
  }

  .showcase__title-link:focus-visible::after {
    outline: 2px solid var(--focus-default);
    outline-offset: 0.25rem;
  }

  .showcase__desktop-brand,
  .showcase__desktop-count {
    display: none;
  }

  .showcase__desktop-count {
    text-align: end;

    @media (min-width: 64rem) {
      display: block;
      font-size: clamp(1.25rem, 1.5vw, 2.5rem);
      line-height: 1.1;
      color: var(--read-default);
    }
  }

  .showcase__desktop-brand {
    @media (min-width: 64rem) {
      display: block;
      font-size: clamp(1.25rem, 1.5vw, 2.5rem);
      line-height: 1.1;
      color: var(--read-default);
    }
  }

  .showcase__desktop-brand span {
    @media (min-width: 64rem) {
      display: block;
    }
  }

  .showcase__desktop-count span {
    @media (min-width: 64rem) {
      display: block;
    }
  }

  .showcase__desktop-brand .showcase__label {
    @media (min-width: 64rem) {
      color: var(--read-lowest);
      margin-top: 0.5rem;
      font-size: 0.75em;
      line-height: 1;
    }
  }

  .showcase__desktop-count .showcase__label {
    @media (min-width: 64rem) {
      color: var(--read-lowest);
      margin-top: 0.5rem;
      font-size: 0.75em;
      line-height: 1;
    }
  }
</style>
