---
import { showcaseItems } from "@/data/showcase";
---

<section aria-labelledby="showcase-title" id="showcase" class="showcase">
  <h2 class="sr-only" id="showcase-title">Showcase</h2>
  <ul class="showcase-list">
    {
      showcaseItems.map((item) => (
        <li class="showcase-item">
          <article class="showcase-card">
            <header class="mobile-meta" aria-label={`${item.brand} metadata`}>
              <p class="meta-group">
                <span class="label">Brand</span>
                <span>{item.brand}</span>
              </p>
              <p class="meta-group align-end">
                <span class="label">Showcase</span>
                <span>{item.countLabel}</span>
              </p>
            </header>

            <figure class="figure">
              <img
                class={`image ${item.mark}`}
                src={item.image.src}
                width={item.image.width}
                height={item.image.height}
                alt=""
                loading="lazy"
                decoding="async"
              />
              <figcaption class={`project-mark ${item.mark}`}>
                {item.markImage ? (
                  <img
                    class="mark-image"
                    src={item.markImage.src}
                    width={item.markImage.width}
                    height={item.markImage.height}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  "wishful.menu"
                )}
              </figcaption>
            </figure>

            <footer class="project-footer">
              <div class="project-copy">
                <h3 class="title-text">
                  {item.title}
                  <a href={`/${item.slug}`} class="title-link">
                    <span class="sr-only">Read showcase</span>
                    <span class="title-arrow" aria-hidden="true">
                      ›
                    </span>
                  </a>
                </h3>
                <p>{item.service}</p>
              </div>

              <p class="desktop-brand">
                <span>{item.brand}</span>
                <span class="label">Brand</span>
              </p>

              <p class="desktop-pagination">
                <span>{item.countLabel}</span>
                <span class="label">Showcase</span>
              </p>
            </footer>
          </article>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .showcase {
    scroll-margin-top: 5rem;
  }

  .showcase-list {
    display: flex;
    flex-direction: column;
    gap: var(--section-gap);
    margin: 0;
    list-style: none;
  }

  .showcase-item {
    position: relative;
  }

  .showcase-card {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: var(--px);
    color: var(--text-strong);

    @media (min-width: 64rem) {
      gap: 1.5rem;
      padding: var(--py) var(--px);
    }
  }

  .mobile-meta,
  .project-footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
  }

  .mobile-meta {
    @media (min-width: 64rem) {
      display: none;
    }
  }

  .label {
    font-size: 0.75rem;
    color: var(--text-dim);
    font-weight: 500;
  }

  .figure {
    position: relative;
    height: 60lvh;
    margin: 0;
    overflow: hidden;
    background: #111;

    @media (min-width: 64rem) {
      height: auto;
      aspect-ratio: 1728 / 723;
    }
  }

  .image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
    &.hyperprint {
      view-transition-name: hyperprint;
    }
    &.donaid {
      view-transition-name: donaid;
    }
    &.wishful {
      view-transition-name: wishful;
    }
  }

  .project-mark {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    display: inline-flex;
    align-items: baseline;
    gap: 0.2rem;
    color: #fff;
    line-height: 1;
    transform: translate(-50%, -50%);
  }

  .mark-image {
    display: block;
    width: auto;
    height: clamp(1rem, 0.75rem + 1vw, 3.5rem);
  }

  .project-mark.wishful {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.5rem, 1rem + 2vw, 3.75rem);
    font-weight: 400;
  }

  .project-footer {
    font-size: clamp(1.25rem, 1.5vw, 2.5rem);
    @media (min-width: 64rem) {
      grid-template-columns: minmax(0, 1.7fr) minmax(16rem, 1fr) auto;
      gap: 0.5rem;
    }
  }
  .title-text {
    color: var(--text-strong);
    font-weight: 500;
    line-height: 1.1;
    text-wrap: balance;
    position: relative;
    &:hover {
      color: #fff;
    }
  }
  .title-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .project-copy > p {
    margin-top: 0.5rem;
    color: var(--text-muted);
    font-weight: 500;
    line-height: 1;
    font-size: 0.9em;

    @media (min-width: 64rem) {
      font-size: 0.75em;
    }
  }

  .desktop-brand,
  .desktop-pagination {
    display: none;

    @media (min-width: 64rem) {
      display: block;
      font-size: clamp(1.25rem, 1.5vw, 2.5rem);
      line-height: 1.1;
      color: var(--text-normal);
      & span {
        display: block;
      }
      & .label {
        color: var(--text-dim);
        margin-top: 0.5rem;
        font-size: 0.75em;
        line-height: 1;
      }
    }
  }
  .desktop-pagination {
    text-align: end;
  }
</style>
