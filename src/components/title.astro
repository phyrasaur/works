---
import Logo from "@/graphics/waf.svg";
import Squiggle from "@/graphics/squiggle.astro";
---

<section class="hero" aria-labelledby="title" data-hero>
  <div class="squiggle-stage" aria-hidden="true">
    <Squiggle />
  </div>

  <div class="hero-footer">
    <hgroup id="title" class="profile">
      <h1>Firas Razak</h1>
      <p>Product Design & Management</p>
    </hgroup>

    <nav class="hero-links" aria-label="Homepage sections">
      <a class="showcase-link" href="#showcase">Showcase</a>
      <a class="contact-link" href="#contact">
        <span><span class="muted">Skip to </span>Contact</span>
        <Logo />
      </a>
    </nav>
  </div>
</section>

<style>
  .hero {
    box-sizing: border-box;
    min-height: 29.125rem;
    display: grid;
    grid-template-rows: minmax(16rem, 1fr) auto;
    padding-block: 1.5rem;
    color: var(--text-strong);

    @media (min-width: 64rem) {
      min-height: 44.125rem;
      padding: 0 var(--px) 0;
      grid-template-rows: minmax(39.875rem, 1fr) 4.25rem;
    }
  }

  .squiggle-stage {
    display: grid;
    align-items: center;
    overflow: hidden;

    @media (min-width: 64rem) {
      overflow: visible;
    }
  }

  .hero-footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 0.75rem;
    padding-inline: var(--px);

    @media (min-width: 64rem) {
      padding-inline: 0;
    }
  }

  .profile {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.125rem;
    font-size: 0.875rem;
    line-height: 1;

    & h1 {
      font-size: inherit;
      font-weight: 500;
    }

    & p {
      color: var(--text-muted);
      line-height: 1.2;
      letter-spacing: 0.03em;
    }

    @media (min-width: 64rem) {
      flex-direction: row;
      gap: 0.75rem;
      font-size: 1rem;
    }
  }

  .hero-links {
    display: flex;
    align-items: end;
    justify-content: end;

    @media (min-width: 64rem) {
      min-width: 10rem;
      flex-direction: column;
      gap: 2.25rem;
    }
  }

  .showcase-link {
    display: none;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-normal);
    font-size: 0.625rem;

    & span {
      writing-mode: sideways-lr;
      text-align: right;
      line-height: 1;
    }

    & .muted {
      color: var(--text-muted);
    }

    & .logo {
      width: 0.625rem;
      height: auto;
      transform: rotate(90deg);
    }

    @media (min-width: 64rem) {
      & span {
        writing-mode: horizontal-tb;
      }

      & .muted,
      & .logo {
        display: none;
      }
    }
  }

  .showcase-link,
  .contact-link {
    @media (min-width: 64rem) {
      display: grid;
      grid-template-columns: auto 4.5rem;
      align-items: center;
      gap: 0.5rem;
      width: max-content;
      margin-inline-end: -6rem;
      color: var(--text-strong);
      font-size: 1rem;
      letter-spacing: 0.02em;

      &::after {
        content: "";
        width: 4.5rem;
        border-top: 1px solid var(--hairline);
      }

      &:hover {
        color: #fff;
      }
    }
  }
</style>
