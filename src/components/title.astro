---
import Squiggle from "@/graphics/squiggle.svg";
---

<section aria-labelledby="title">
  <hgroup id="title">
    <h1>Firas Razak</h1>
    <p>Product Design & Management</p>
  </hgroup>
  <Squiggle />
  <nav>
    <a href="#showcase">Showcase</a>
    <a href="#playground">Playground</a>
    <a href="#contact">Contact</a>
  </nav>
</section>
<style>
  [aria-labelledby="title"] {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    grid-template-rows: minmax(0, 1fr) auto;
    padding-inline: var(--px);
    min-height: 60lvh;
    margin-top: calc(var(--py) * -2);
    padding-bottom: 1rem;
    & nav {
      grid-row: 1 / -1;
      grid-column: 2;
      display: grid;
      align-content: end;
      text-align: end;
      gap: 2rem;
      & a {
        --col-gap: 1ch;
        text-decoration: none;
        color: inherit;
        display: inline-grid;
        grid-template-columns: auto calc(var(--px) - var(--col-gap));
        column-gap: var(--col-gap);
        row-gap: 1rem;
        margin-inline-end: calc(var(--px) * -1);
        &:hover {
          color: #fff;
        }
        &::after {
          content: "";
          border-top: 1px solid;
          opacity: 0.3;
          grid-column: 2;
          align-self: center;
          justify-self: stretch;
        }
      }
    }
  }
  #title {
    font-size: 1rem;
    & > h1 {
      line-height: 1.5;
      font-size: 1.5em;
      font-weight: 600;
    }
    & > p {
      letter-spacing: 3%;
      line-height: 1;
    }
  }
  .squiggle {
    align-self: safe center;
    width: 100%;
    height: auto;
    margin-block: -9% -9%;
    grid-row: 1;
    grid-column: 1 / 3;
  }
</style>
