<footer id="contact" class="contact" aria-labelledby="contact-title">
  <section class="contact__about" aria-label="About Firas Razak">
    <p class="contact__definition">
      <dfn>Firas</dfn>
      <span> - n. (Arabic) an intuitive, insightful, perspicacious person</span>
    </p>
    <p class="contact__claim">
      A multidisciplinary product designer who turns ambiguous ideas into viable
      products through insights
    </p>
    <p class="contact__description">
      My experience spans business operations, design, development, and
      management. Beyond screens, I solve problems systemically aligning users,
      business goals, and team workflows
    </p>
  </section>
  <aside class="contact__links" aria-label="Contact links">
    <div class="contact__primary-links">
      <a href="mailto:hi@firas.works">
        <span>hi@firas.works</span>
        <svg
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
          ></path>
        </svg>
      </a>
      <a href="https://linkedin.com/in/firasrazak">
        <span>@firasrazak</span>
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect
            x="2.75"
            y="2.75"
            width="18.5"
            height="18.5"
            rx="3.25"
            stroke="currentColor"
            stroke-width="1.5"></rect>
          <path
            d="M7.27 9.86H8.642V17H7.27V9.86ZM7.186 7.102H8.74V8.586H7.186V7.102ZM14.9421 12.422C14.9421 11.918 14.8208 11.526 14.5781 11.246C14.3448 10.966 13.9808 10.826 13.4861 10.826C12.8981 10.826 12.4268 10.9893 12.0721 11.316C11.7268 11.6427 11.5541 12.0767 11.5541 12.618V17H10.1821V9.86H11.5541V10.756H11.5821C11.7968 10.4387 12.1001 10.1773 12.4921 9.972C12.8841 9.75733 13.3648 9.65 13.9341 9.65C14.6341 9.65 15.2034 9.85533 15.6421 10.266C16.0901 10.6673 16.3141 11.26 16.3141 12.044V17H14.9421V12.422Z"
            fill="currentColor"></path>
        </svg>
      </a>
    </div>
    <a href="/resume.pdf" download>
      <span>Resume</span>
      <svg
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
        ></path>
      </svg>
    </a>
  </aside>
</footer>

<style>
  .contact {
    box-sizing: border-box;
    container-type: inline-size;
    min-height: 100svh;
    display: grid;
    grid-template-rows: 1fr auto 1fr;
    gap: 2rem;
    padding: var(--py) var(--px);
    @media (min-width: 64rem) {
      padding-block: calc(var(--py) * 3) calc(var(--py) * 2);
      grid-template-rows: 1fr;
      grid-template-columns: 1fr;
    }
    @media (min-width: 80rem) {
      padding-block: calc(var(--py) * 1.75) calc(var(--py) * 1.5);
    }

    & .contact__about {
      grid-row: 2;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      gap: 0.75rem;
      align-items: start;

      @media (min-width: 64rem) {
        grid-row: 1;
        gap: 1.5em;
      }
    }

    & .contact__definition {
      grid-column: 2;
      grid-row: 1 / span 2;
      font-size: clamp(0.85rem, 4cqw, 1.5rem);
      line-height: 1.1;
      text-align: right;
      max-width: min-content;
      color: var(--text-muted);

      & dfn {
        display: block;
        font-style: normal;
        font-weight: 500;
        color: var(--text-strong);
      }

      @media (min-width: 64rem) {
        text-align: left;
        grid-column: 1;
        grid-row: 1;
        max-width: none;

        & dfn {
          display: inline;
        }

        & span {
          font-weight: 300;
        }
      }
    }

    & .contact__claim {
      font-size: clamp(1.25rem, 9cqw, 3.5rem);
      line-height: 1.1;
      color: var(--text-strong);
      max-width: 24ch;

      @media (min-width: 64rem) {
        align-self: center;
      }

      @media (min-width: 80rem) {
        font-size: clamp(3.5rem, 10cqw, 5rem);
      }
    }

    & .contact__description {
      grid-column: 1;
      color: var(--text-muted);
      font-size: clamp(1rem, 4cqw, 1.75rem);
      line-height: 1.35;
      letter-spacing: 0.04em;
      max-width: 40ch;
    }

    & .contact__links {
      grid-row: 3;
      align-self: end;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      font-size: 0.875rem;

      @media (min-width: 64rem) {
        grid-row: 1;
        grid-column: 2;
        align-self: stretch;
        flex-direction: column;
        align-items: flex-end;
        justify-content: space-between;
        font-size: 1rem;
      }

      & a {
        display: inline-flex;
        align-items: center;
        gap: 0.25em;
        color: var(--text-strong);
        line-height: 1;

        &:hover {
          color: #fff;
          text-decoration: underline;
        }

        & svg {
          width: 1em;
          height: 1em;
        }
      }
    }

    & .contact__primary-links {
      display: contents;

      @media (min-width: 64rem) {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 3.25rem;
      }
    }
  }
</style>
