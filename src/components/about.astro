---
import Logo from "@/graphics/waf.svg";
---

<footer id="contact" class="contact-section" aria-labelledby="contact-title">
  <div class="contact-heading">
    <Logo />
    <hgroup>
      <h2 id="contact-title">Firas Razak</h2>
      <p>Product Design & Management</p>
    </hgroup>
    <a href="#contact" class="desktop-contact-link">Contact</a>
    <p class="mobile-contact-label" aria-hidden="true">Contact</p>
  </div>

  <div class="contact-body">
    <section class="about-copy" aria-label="About Firas Razak">
      <p class="definition">
        <dfn>Firas</dfn>
        <span> - n. (Arabic) an intuitive, insightful, perspicacious person</span>
      </p>
      <p class="claim">
        A multidisciplinary product designer who turns ambiguous ideas into
        viable products through insights
      </p>
      <p class="description">
        My experience spans business operations, design, development, and
        management. Beyond screens, I solve problems systemically aligning
        users, business goals, and team workflows
      </p>
    </section>

    <aside class="contact-links" aria-label="Contact links">
      <div class="primary-links">
        <a href="mailto:hi@firas.works">
          <span>hi@firas.works</span>
          <svg
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
        </a>
        <a href="https://linkedin.com/in/firasrazak">
          <span>@firasrazak</span>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect
              x="2.75"
              y="2.75"
              width="18.5"
              height="18.5"
              rx="3.25"
              stroke="currentColor"
              stroke-width="1.5"></rect>
            <path
              d="M7.27 9.86H8.642V17H7.27V9.86ZM7.186 7.102H8.74V8.586H7.186V7.102ZM14.9421 12.422C14.9421 11.918 14.8208 11.526 14.5781 11.246C14.3448 10.966 13.9808 10.826 13.4861 10.826C12.8981 10.826 12.4268 10.9893 12.0721 11.316C11.7268 11.6427 11.5541 12.0767 11.5541 12.618V17H10.1821V9.86H11.5541V10.756H11.5821C11.7968 10.4387 12.1001 10.1773 12.4921 9.972C12.8841 9.75733 13.3648 9.65 13.9341 9.65C14.6341 9.65 15.2034 9.85533 15.6421 10.266C16.0901 10.6673 16.3141 11.26 16.3141 12.044V17H14.9421V12.422Z"
              fill="currentColor"></path>
          </svg>
        </a>
      </div>
      <a href="/resume.pdf" download>
        <span>Resume</span>
        <svg
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
          ></path>
        </svg>
      </a>
    </aside>
  </div>
</footer>

<style>
  .contact-section {
    box-sizing: border-box;
    min-height: 42.625rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 7.5rem;
    padding: var(--px);
    color: var(--text-strong);

    @media (min-width: 64rem) {
      min-height: 68.1875rem;
      gap: 4.5rem;
      padding-block: 6rem 10rem;
    }
  }

  .contact-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;

    & .logo {
      width: 1.25rem;
      height: auto;
    }

    & hgroup {
      display: none;
    }

    @media (min-width: 64rem) {
      align-items: center;

      & .logo {
        width: 2.25rem;
      }

      & hgroup {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.25rem;
        letter-spacing: 0.02em;

        & h2 {
          font-size: inherit;
          font-weight: 700;
        }

        & p {
          color: var(--text-normal);
        }
      }
    }
  }

  .desktop-contact-link {
    display: none;

    @media (min-width: 64rem) {
      display: inline-grid;
      grid-template-columns: auto 4.5rem;
      align-items: center;
      gap: 1rem;
      margin-inline-end: -6rem;
      color: var(--text-strong);
      font-size: 1.25rem;

      &::after {
        content: "";
        border-top: 1px solid var(--hairline);
      }
    }
  }

  .mobile-contact-label {
    color: var(--text-dim);
    font-size: 1.75rem;
    writing-mode: sideways-lr;

    @media (min-width: 64rem) {
      display: none;
    }
  }

  .contact-body {
    display: flex;
    flex-direction: column;
    gap: 7.5rem;

    @media (min-width: 64rem) {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 3.5rem;
    }
  }

  .about-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 4.5rem;
    gap: 0.75rem;
    align-items: start;

    @media (min-width: 64rem) {
      display: flex;
      flex-direction: column;
      gap: 3.5rem;
      max-width: 71.25rem;
    }
  }

  .definition {
    grid-column: 2;
    grid-row: 1 / span 2;
    color: var(--text-strong);
    font-size: 0.75rem;
    line-height: 1.1;
    text-align: right;

    & dfn {
      display: block;
      font-style: normal;
      font-weight: 500;
    }

    @media (min-width: 64rem) {
      max-width: 71.25rem;
      color: var(--text-strong);
      font-size: 2rem;
      line-height: 1.1;
      text-align: left;

      & dfn {
        display: inline;
      }

      & span {
        color: var(--text-normal);
        font-weight: 300;
      }
    }
  }

  .claim {
    max-width: 12ch;
    font-size: 1.5rem;
    line-height: 1.1;

    @media (min-width: 64rem) {
      max-width: 14ch;
      color: var(--text-strong);
      font-size: clamp(4rem, 5vw, 5.25rem);
      line-height: 1.1;
    }
  }

  .description {
    grid-column: 1;
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.1;

    @media (min-width: 64rem) {
      max-width: 24ch;
      color: var(--text-muted);
      font-size: clamp(2.5rem, 3vw, 3rem);
      line-height: 1.1;
    }
  }

  .contact-links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;

    & a {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      color: var(--text-strong);
      font-size: 0.875rem;
      line-height: 1;

      &:hover {
        color: #fff;
        text-decoration: underline;
      }

      & svg {
        width: 0.75rem;
        height: 0.75rem;
      }
    }

    @media (min-width: 64rem) {
      min-width: 12.875rem;
      align-items: flex-end;
      flex-direction: column;
      justify-content: space-between;

      & a {
        gap: 0.625rem;
        font-size: 1.75rem;

        & svg {
          width: 1.5rem;
          height: 1.5rem;
        }
      }
    }
  }

  .primary-links {
    display: contents;

    @media (min-width: 64rem) {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 1.5rem;
    }
  }
</style>
