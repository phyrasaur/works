---
import { Font } from "astro:assets";
---

<meta charset="utf-8" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<Font cssVariable="--font-pp-neue-montreal" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#000" />
<meta name="color-scheme" content="dark" />
<style is:global>
  @view-transition {
    navigation: auto;
  }
  :root {
    --page-pad: 1.5rem;
    --page-pad-lg: 6rem;
    --section-gap: 0.25rem;
    --text-strong: #ffffffe6;
    --text-normal: #ffffffbf;
    --text-muted: #ffffff9e;
    --text-dim: #ffffff66;
    --hairline: #ffffff40;
    --surface: #000;
    --page-max: 120rem;
    --px: var(--page-pad);
    --py: 1.5rem;
    --dvh: 100dvh;
    --lvh: 100lvh;
    --vh: 100vh;

    @media screen and (min-width: 48rem) {
      --px: 6rem;
      --py: 2.5rem;
    }
    @media screen and (min-width: 96rem) {
      --py: 6rem;
    }
  }

  html {
    scroll-behavior: smooth;
  }
  body {
    font-family:
      var(--font-pp-neue-montreal),
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
    background-color: black;
    color: var(--text-normal);
    line-height: 1;
    font-size: 0.875rem;
    margin: 0;
  }
  main {
    display: flex;
    flex-direction: column;
    gap: var(--section-gap);
  }
  body > .site-banner,
  main {
    box-sizing: border-box;
    width: 100%;
    max-width: var(--page-max);
    margin-inline: auto;
  }
  button {
    background-color: transparent;
    border: none;
    border-radius: 0;
    font-size: inherit;
    color: inherit;
    font-family: inherit;
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6,
  p,
  figure {
    margin: 0;
  }
  ul {
    padding: 0;
  }
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  a {
    color: inherit;
    text-decoration: none;
    &:visited {
      color: inherit;
    }
  }
  button:hover {
    cursor: pointer;
  }
  .contents {
    display: contents;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border-width: 0;
  }
  @view-transition {
    navigation: auto;
  }

  ::view-transition-group(root) {
    animation-duration: 250ms;
  }

  ::view-transition-old(root) {
    animation: fade-out 250ms ease;
  }

  ::view-transition-new(root) {
    animation: fade-in 250ms ease;
  }

  @keyframes fade-out {
    to {
      opacity: 0;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
  }
</style>
